{% liquid
  assign enable_rtl = settings.rtl
  assign iso_code = request.locale.iso_code
  assign lis_language_rtl = settings.language_rtl
  if lis_language_rtl != blank
    if lis_language_rtl contains iso_code
      assign enable_rtl = true
    else
      assign enable_rtl = false
    endif
  endif

  assign load_swiper_assets = false
  if request.page_type == 'index' or request.page_type == 'product' or request.page_type == 'collection' or request.page_type == 'search' or request.page_type == 'cart'
    assign load_swiper_assets = true
  endif

  assign load_motion_effects = false
  if settings.scroll_animation != 'none' or settings.zoom_image
    assign load_motion_effects = true
  endif

  assign account_open_as = settings.open_as | default: 'show_popup_login'
  assign load_account_popup_assets = false
  if account_open_as == 'show_popup_login' and shop.customer_accounts_enabled
    assign load_account_popup_assets = true
  endif

  assign defer_theme_assets_until_age_gate = true
  if request.design_mode
    assign defer_theme_assets_until_age_gate = false
  endif
%}

<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="">
    {%- comment -%} Preconnect a cdn.shopify.com — ahorra DNS+TLS handshake (~200-400ms)
      en el primer fetch del logo del age gate (LCP element), fuentes e imágenes.
      Solo afecta DNS/TLS, no descarga recursos extra. {%- endcomment -%}
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
    {%- comment -%} Preload del LCP product image en PDP. Sin esto, el browser
      no descubre la imagen hasta que parsea ~9600 líneas de HTML (Load Delay
      ~6s en Lighthouse mobile). El imagesrcset/imagesizes coincide con el
      widths/sizes que renderiza product-media-layout.liquid para el featured
      media, así el preload scanner pide exactamente la URL que el <img>
      necesita — cero double-fetch.
      Sólo aplica en page_type 'product' y cuando hay imagen disponible. {%- endcomment -%}
    {%- if request.page_type == 'product' and product != blank -%}
      {%- liquid
        assign pdp_lcp_media = product.selected_or_first_available_variant.featured_media
        if pdp_lcp_media == blank or pdp_lcp_media == nil
          assign pdp_lcp_media = product.featured_media
        endif
        assign pdp_lcp_image = pdp_lcp_media.preview_image
      -%}
      {%- if pdp_lcp_image != blank -%}
        <link
          rel="preload"
          as="image"
          imagesrcset="{{ pdp_lcp_image | image_url: width: 360 }} 360w, {{ pdp_lcp_image | image_url: width: 480 }} 480w, {{ pdp_lcp_image | image_url: width: 550 }} 550w, {{ pdp_lcp_image | image_url: width: 660 }} 660w, {{ pdp_lcp_image | image_url: width: 720 }} 720w, {{ pdp_lcp_image | image_url: width: 900 }} 900w, {{ pdp_lcp_image | image_url: width: 1000 }} 1000w, {{ pdp_lcp_image | image_url: width: 1200 }} 1200w, {{ pdp_lcp_image | image_url: width: 1400 }} 1400w, {{ pdp_lcp_image | image_url: width: 1600 }} 1600w"
          imagesizes="(min-width: 1200px) 720px, (min-width: 768px) 50vw, 100vw"
          fetchpriority="high">
      {%- endif -%}
    {%- endif -%}
    {%- comment -%} Detección temprana de age-verified: añade clase a <html>
      para que CSS y JS posteriores (deferred-assets-loader) puedan tomar
      decisiones según el estado. El preload condicional del logo del age
      gate vive en el bloque (blocks/ai_gen_block_3f4d556.liquid) porque
      ahí tenemos logo_width_2x dinámico que evita drift de URL. {%- endcomment -%}
    <script>
      (function () {
        var cookieName = 'age_verified_diyvape';
        var parseVerified = function (raw) {
          if (!raw) return false;
          try {
            var parsed = JSON.parse(decodeURIComponent(raw));
            return Boolean(parsed && parsed.verified && parsed.dob && parsed.id);
          } catch (error) {
            try {
              var fallback = JSON.parse(raw);
              return Boolean(fallback && fallback.verified && fallback.dob && fallback.id);
            } catch (innerError) {
              return false;
            }
          }
        };
        var getCookie = function (name) {
          var prefix = name + '=';
          var parts = document.cookie ? document.cookie.split(';') : [];
          for (var i = 0; i < parts.length; i += 1) {
            var value = parts[i].trim();
            if (value.indexOf(prefix) === 0) return value.slice(prefix.length);
          }
          return '';
        };
        try {
          if (parseVerified(getCookie(cookieName)) || parseVerified(localStorage.getItem(cookieName))) {
            document.documentElement.classList.add('age-gate-verified');
          }
        } catch (error) {}
      })();
    </script>
    <link rel="canonical" href="{{ canonical_url }}">
    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}
    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains 'DIY' %} &ndash; {{ shop.name }}{% endunless -%}
    </title>
    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}
    {% render 'meta-tags' %}

    {% comment %} SEO: noindex para vendors {% endcomment %}
    {%- if canonical_url contains '/vendors' -%}
      <meta name="robots" content="noindex, follow">
    {%- endif -%}

    {% comment %} SEO: noindex para colecciones con filtros activos o vista AJAX (inyectado via JS porque Liquid no accede a query params desde el layout) {% endcomment %}
    <script>if(location.search.indexOf('filter.')>-1||location.search.indexOf('view=ajax')>-1){document.head.insertAdjacentHTML('beforeend','<meta name="robots" content="noindex, follow">')}</script>
    {% render 'schema-local-business' %}
    {% render 'schema-homepage-products' %}
    {% render 'schema-faq-collection' %}
    {% render 'schema-faq-product' %}
    {% render 'schema-faq-page' %}
    {% render 'breadcrumb-schema' %}
        
    {% if defer_theme_assets_until_age_gate %}
      <script>
        window.diyvapeDeferredAssets = window.diyvapeDeferredAssets || [];
        window.diyvapeDeferredAssets.push(
          { type: 'style', href: {{ 'critical.css' | asset_url | json }} },
          {% if request.page_type == 'collection' or request.page_type == 'index' or request.page_type == 'search' %}
            { type: 'style', href: {{ 'product-card.css' | asset_url | json }} },
          {% else %}
            { type: 'style', href: {{ 'product-card.css' | asset_url | json }} },
          {% endif %}
          {% if load_swiper_assets %}
            { type: 'style', href: {{ 'swiper-bundle.min.css' | asset_url | json }} },
          {% endif %}
          {% if request.page_type == 'collection' %}
            { type: 'style', href: {{ 'collection-page.css' | asset_url | json }} },
          {% endif %}
          {% if request.page_type == 'product' %}
            {% if template.suffix == 'layout-2' %}
              { type: 'style', href: {{ 'main-product-layout-2.css' | asset_url | json }} },
            {% else %}
              { type: 'style', href: {{ 'main-product.css' | asset_url | json }} },
            {% endif %}
            { type: 'style', href: {{ 'component-deferred-media.css' | asset_url | json }} },
            { type: 'style', href: {{ 'diyvape-pdp-components.css' | asset_url | json }} },
          {% endif %}
          { type: 'style', href: {{ 'judgeme-reviews.css' | asset_url | json }}, visual: false },
          { type: 'style', href: {{ 'theme.css' | asset_url | json }} },
          { type: 'style', href: {{ 'popup.css' | asset_url | json }}, visual: false }
          {% if load_account_popup_assets %}
            ,{ type: 'style', href: {{ 'header-account-popup.css' | asset_url | json }}, visual: false }
          {% endif %}
        );
      </script>
      {% render 'deferred-assets-loader' %}
    {% endif %}
    {%- comment -%} critical-base inlined (era assets/critical-base.css) — elimina
      1 render-blocking HTTP request. Ahorro ~50-200ms FCP en cold cache. {%- endcomment -%}
    {% render 'critical-base' %}
    {{ content_for_header }}
    {% if defer_theme_assets_until_age_gate %}
      <noscript>
        {{ 'critical.css' | asset_url | stylesheet_tag }}
        {{ 'product-card.css' | asset_url | stylesheet_tag }}
        {% if load_swiper_assets %}{{ 'swiper-bundle.min.css' | asset_url | stylesheet_tag }}{% endif %}
        {{ 'judgeme-reviews.css' | asset_url | stylesheet_tag }}
        {{ 'theme.css' | asset_url | stylesheet_tag }}
        {{ 'popup.css' | asset_url | stylesheet_tag }}
        {% if load_account_popup_assets %}{{ 'header-account-popup.css' | asset_url | stylesheet_tag }}{% endif %}
      </noscript>
    {% else %}
      <link rel="stylesheet" href="{{ 'critical.css' | asset_url }}" media="print" onload="this.media='all'">
      <noscript>{{ 'critical.css' | asset_url | stylesheet_tag }}</noscript>
    {% endif %}
    {% if enable_rtl %}{{ 'rtl.css' | asset_url | stylesheet_tag: preload: true }}{% endif %}
    {% unless defer_theme_assets_until_age_gate %}
      {%- comment -%} INP optimization — preload solo donde el CSS es crítico above-fold {%- endcomment -%}
      {%- if request.page_type == 'collection' or request.page_type == 'index' or request.page_type == 'search' -%}
        {{ 'product-card.css' | asset_url | stylesheet_tag: preload: true }}
      {%- else -%}
        <link rel="stylesheet" href="{{ 'product-card.css' | asset_url }}" media="print" onload="this.media='all'">
        <noscript><link rel="stylesheet" href="{{ 'product-card.css' | asset_url }}"></noscript>
      {%- endif -%}
      {%- if load_swiper_assets -%}
        {%- if request.page_type == 'index' -%}
          {{ 'swiper-bundle.min.css' | asset_url | stylesheet_tag: preload: true }}
        {%- else -%}
          <link rel="stylesheet" href="{{ 'swiper-bundle.min.css' | asset_url }}" media="print" onload="this.media='all'">
          <noscript><link rel="stylesheet" href="{{ 'swiper-bundle.min.css' | asset_url }}"></noscript>
        {%- endif -%}
      {%- endif -%}
      <link rel="stylesheet" href="{{ 'judgeme-reviews.css' | asset_url }}" media="print" onload="this.media='all'">
      <noscript><link rel="stylesheet" href="{{ 'judgeme-reviews.css' | asset_url }}"></noscript>
    {% endunless %}
    {% render 'font-variables' %}
    {% if request.design_mode %}
      {{ 'design-mode.css' | asset_url | stylesheet_tag: preload: true }}
    {% endif %}
    {% style %}
      {% for scheme in settings.color_schemes -%}
        {% # theme-check-disable UndefinedObject %}
        {% assign scheme_classes = scheme_classes | append: ', .color-' | append: scheme.id %}
        {% # theme-check-disable UndefinedObject %}
        {% if forloop.index == 1 -%}
          :root,
        {%- endif %}
        .color-{{ scheme.id }} {
          --color-background: {{ scheme.settings.background }};
          {% if scheme.settings.background_gradient != empty %}
          --gradient-background: {{ scheme.settings.background_gradient }};
          {% else %}
          --gradient-background: {{ scheme.settings.background }};
          {% endif %}
          --color-primary: {{ scheme.settings.primary_color }};
          --color-primary-rgb: {{ scheme.settings.primary_color.red }}, {{ scheme.settings.primary_color.green }}, {{ scheme.settings.primary_color.blue }};
          --color-text: {{ scheme.settings.text_color }};
          --color-text-rgb: {{ scheme.settings.text_color.red }}, {{ scheme.settings.text_color.green }}, {{ scheme.settings.text_color.blue }};
          --color-heading: {{ scheme.settings.heading_color }};
          --color-heading-rgb:{{ scheme.settings.heading_color.red }}, {{ scheme.settings.heading_color.green }}, {{ scheme.settings.heading_color.blue }};
          --color-link: {{ scheme.settings.text_color }};
          --color-link-hover: {{ scheme.settings.primary_color }};
          --color-border: {{ scheme.settings.border_color }};
          /* Button primary */
          --btn-primary-color: {{ scheme.settings.btn_primary_color }};
          --btn-primary-hover-color: {{ scheme.settings.btn_primary_hover_color }};
          --btn-primary-bg-color: {{ scheme.settings.btn_primary_background }};
          {% if scheme.settings.btn_primary_gradient != blank %}
            --btn-primary-bg-graident-color: {{ scheme.settings.btn_primary_gradient }};
          {% else %}
            --btn-primary-bg-graident-color: {{ scheme.settings.btn_primary_background }};
          {% endif %}
          --btn-primary-hover-bg-color: {{ scheme.settings.btn_primary_hover_background }};
          {% if scheme.settings.btn_primary_hover_background_gradient != blank %}
            --btn-primary-hover-bg-color-graident: {{ scheme.settings.btn_primary_hover_background_gradient }};
          {% else %}
            --btn-primary-hover-bg-color-graident: {{ scheme.settings.btn_primary_hover_background }};
          {% endif %}
          /* Button outline */
          --btn-outline-color: {{ scheme.settings.btn_outline_color }};
          --btn-outline-border-color: {{ scheme.settings.btn_outline_border_color }};
          /* Button link */
          --btn-link-color: {{ scheme.settings.button_link_color }};
          --btn-link-hover-color: {{ scheme.settings.button_link_hover_color }};
          --input-color: var(--color-text);
          --input-placeholder-color: rgba(var(--color-heading-rgb), 0.55);
          --input-bg: rgba({{ scheme.settings.background.red }}, {{ scheme.settings.background.green }}, {{ scheme.settings.background.blue }}, 0.6);
        }
      {% endfor %}
      {{ scheme_classes | prepend: 'body' }} {
        color: var(--color-text);
        background-color: var(--color-background);
      }
      :root {
        --border-color-base: #e5e5e5;
        --light-grey-color: #f5f5f5;
        {% if settings.enable_rounded %} --rounded-radius: {{ settings.rounded_corner }}px;{% endif %}
        --logo-width: {{ settings.mobile_logo_width }}px;
        --body-font-size: {{ settings.body_font_size }}px;
        --body-line-height: 1.714;
        --body-weight: {{ settings.body_font_weight }};
        --heading-font-scale: {{ settings.heading_font_scale | divided_by: 100.0 }};
        --heading-text-transform: {{ settings.heading_text_transform }};
        --heading-letter-spacing: {% if settings.heading_letter_spacing == 'negative' %}-0.034em{% else %}{{ settings.heading_letter_spacing }}{% endif %};
        --heading-weight: {{ settings.heading_font_weight }};
        --subheading-weight: {{ settings.subheading_font_weight }};
        --medium-font-weight: {% if settings.menu_font == 'body_font' %}{{ settings.body_font.family }}{% else %}{{ settings.heading_font.family }}{% endif %}, {{ settings.body_font.fallback_families }};
        --btn-text-transform: {{ settings.btn_text_transform }};
        --btn-radius: {{ settings.button_radius }}px;
        --btn-font-size: var(--body-font-size, 1.4rem);
        --btn-padding-y: 1.5rem;
        --btn-padding-x: 3rem;
        --btn-letter-spacing:  {% if settings.heading_letter_spacing == 'negative' %}calc(var(--heading-letter-spacing) + 0.01em){% else %}calc(var(--heading-letter-spacing) - 0.01em){% endif %};
        --input-height: 5rem;
        {% if settings.rounded_corner > 1 %}
        --input-padding: 1rem 2rem;
        {% else %}
        --input-padding: 1rem 1.5rem;
        {% endif %}
        --inputs-border-width: 1px;
        --input-color: var(--color-text);
        --input-border-radius: var(--btn-radius);
        --input-font-size:  {% if settings.body_font_size < 16 %}16px{% else %}{{ settings.body_font_size }}{% endif %}  ;
        --input-placeholder-color: rgba(var(--color-heading-rgb), 0.6);
        --page-width: {{ settings.page_width }}px;
        --page-width-value: {{ settings.page_width }};
        --fluid-container-width: {{ settings.fluid_container_width }}px;
        --fluid-container-width-value: {{ settings.fluid_container_width }}px;
        --color-white: #FFF;
        --color-dark: #111;
        --h0-size: calc(var(--heading-font-scale) * 4.8rem);
        --h1-size: calc(var(--heading-font-scale) * 4rem);
        --h2-size: calc(var(--heading-font-scale) * 3.6rem);
        --h3-size: calc(var(--heading-font-scale) * 3rem);
        --h4-size:  calc(var(--heading-font-scale) * 2.4rem);
        --h5-size: calc(var(--heading-font-scale) * 1.8rem);
        --h6-size: calc(var(--heading-font-scale) * 1.6rem);
        --transition: 0.4s cubic-bezier(.3, 1, .3, 1);
        --duration-short: 0.3s;
        --duration-long: 0.5s;
        --transition-popup: transform .6s cubic-bezier(.7,0,.2,1);
        --zoom-transform: scale(1.05);
        --overlay-bg: rgba(0, 0, 0, 0.50);
        --grey-color: #f5f5f5;
        --section-spacing: {{ settings.space_mobile }}px;
        --bs-gutter-x: 1.5rem;
        --shadow: 5px 0px 30px 0px rgba(0, 0, 0, 0.08);
        /* Badge color */
        --bages-radius: {{ settings.badges_rounded_corner }}px;
        --bages-sale-color: {{ settings.sale_color }};
        --bages-sale-bg-color: {{ settings.sale_background }};
        --bages-new-color: {{ settings.new_color }};
        --bages-new-bg-color: {{ settings.new_background }};
        --bages-pre-order-color: {{ settings.pre_order_color }};
        --bages-pre-order-bg-color: {{ settings.pre_order_background }};
        --bages-sold-out-color: {{ settings.sold_out_color }};
        --bages-sold-out-bg-color: {{ settings.sold_out_background }};
        --bages-custom-color: {{ settings.custom_badge_color }};
        --bages-custom-bg-color: {{ settings.custom_badge_background }};
        --responsive-rate: ((100vw - 575px) / (1600 - 575));
      }
      @media (min-width: 768px) {
        :root{
          --section-spacing: {{ settings.spacing_desktop }}px;
          --logo-width: {{ settings.logo_width }}px;
          --btn-padding-y: 1.5rem;
           --btn-padding-x: 5.5rem;
           --input-font-size: calc(var(--body-font-size) - 1px);
        }
      }
      @media (max-width: 1024.5px) {
        :root {
          --transition-popup: transform .35s cubic-bezier(.7,0,.2,1);
        }
      }
    {% endstyle %}
    {% if defer_theme_assets_until_age_gate %}
      <script>
        window.diyvapeDeferredAssets.push(
          {% if load_account_popup_assets %}
            { type: 'script', src: {{ 'header-account-popup.js' | asset_url | json }} },
          {% endif %}
          {% if load_swiper_assets %}
            { type: 'script', src: {{ 'swiper-bundle.min.js' | asset_url | json }} },
          {% endif %}
          { type: 'script', src: {{ 'motion.min.js' | asset_url | json }}, module: true },
          { type: 'script', src: {{ 'utils.js' | asset_url | json }} },
          { type: 'script', src: {{ 'global.js' | asset_url | json }} }
          {% if load_motion_effects %}
            ,{ type: 'script', src: {{ 'motion-effect.js' | asset_url | json }} }
          {% endif %}
        );
      </script>
    {% else %}
      <link rel="stylesheet" href="{{ 'theme.css' | asset_url }}" media="print" onload="this.media='all'">
      <noscript><link rel="stylesheet" href="{{ 'theme.css' | asset_url }}"></noscript>
      <link rel="stylesheet" href="{{ 'popup.css' | asset_url }}" media="print" onload="this.media='all'">
      <noscript><link rel="stylesheet" href="{{ 'popup.css' | asset_url }}"></noscript>
      {% if load_account_popup_assets %}
        <link rel="stylesheet" href="{{ 'header-account-popup.css' | asset_url }}" media="print" onload="this.media='all'">
        <noscript><link rel="stylesheet" href="{{ 'header-account-popup.css' | asset_url }}"></noscript>
        <script src="{{ 'header-account-popup.js' | asset_url }}" defer="defer"></script>
      {% endif %}
      {% if load_swiper_assets %}
        <script src="{{ 'swiper-bundle.min.js' | asset_url }}" defer="defer"></script>
      {% endif %}
      <script src="{{ 'motion.min.js' | asset_url }}" type="module" defer="defer"></script>
      <script src="{{ 'utils.js' | asset_url }}" defer="defer"></script>
      <script src="{{ 'global.js' | asset_url }}" defer="defer"></script>
      {% if load_motion_effects %}
        <script src="{{ 'motion-effect.js' | asset_url }}" defer="defer"></script>
      {% endif %}
    {% endif %}
    <script>
      document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
      if (Shopify.designMode) {
        document.documentElement.classList.add('shopify-design-mode');
      }
    </script>
  {% render 'diyvape-pdp-assets', defer_by_age_gate: defer_theme_assets_until_age_gate %}
  </head>
  <body
    class="gradient{% if settings.rounded_corner > 1 and settings.enable_rounded %} rounded-style{% endif %}{% if settings.action_after_add_cart == 'show_popup' %} minicart_type-popup{% endif %}{% if enable_rtl %} rtl{% endif %} {% if request.page_type == 'cart'%}template-cart{% endif %} {{ request.page_type }}"
  >
    {%- liquid
      sections 'overlay-group'
      render 'preload-page'
      sections 'header-group'
    -%}

    <main id="MainContent" class="content-for-layout focus-none" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>
    {% sections 'footer-group' %}
    {%- liquid
      section 'mobile-navigation-bar'
      section 'product-quickview'
      section 'custom-colors'
      section 'fake-order'
    -%}
    {% section 'top-search' %}
    {%- render 'minicart' -%}
    {%- render 'scripts-tag', defer_by_age_gate: defer_theme_assets_until_age_gate -%}
    {%- render 'sprite-svg' -%}
    {%- render 'content-bottom' -%}
  </body>
</html>
