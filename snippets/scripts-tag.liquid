{%- liquid
  assign t = template | split: '.' | first
  assign admin_vi = request.design_mode
  assign license_salt = shop.permanent_domain | append: "GlzSalt25" | sha256 | slice: 0, 16
  assign encoded_shop_email = shop.email | base64_encode
  assign hmac = shop.email | hmac_sha256: license_salt
  assign encoded_license = encoded_shop_email | append: ":" | append: hmac | base64_encode
-%}
{%- if defer_by_age_gate -%}
  <script>
    window.diyvapeDeferredAssets.push(
      { type: 'script', src: {{ 'tingle.js' | asset_url | json }} },
      { type: 'script', src: {{ 'theme.js' | asset_url | json }}, module: true }
      {%- case t -%}
        {%- when 'collection' and collection.handle -%}
          ,{ type: 'script', src: {{ 'collection.js' | asset_url | json }} }
        {%- when 'product' -%}
          ,{ type: 'script', src: {{ 'main-product.js' | asset_url | json }} }
          {%- liquid
            assign has_360_image = false
            for media in product.media
              if media.media_type == 'image' and media.alt == 'image-360'
                assign has_360_image = true
                break
              endif
            endfor
          -%}
          {%- if has_360_image -%}
            ,{ type: 'script', src: {{ 'js-cloudimage-360-view.min.js' | asset_url | json }} }
          {%- endif -%}
        {%- when 'search' -%}
          ,{ type: 'script', src: {{ 'collection.js' | asset_url | json }} }
      {%- endcase -%}
    );
  </script>
{%- else -%}
  <script src="{{ 'tingle.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'theme.js' | asset_url }}"  defer="defer" type="module"></script>
  {%- case t -%}
    {%- when 'collection' and collection.handle -%}
      <script src="{{ 'collection.js' | asset_url }}" defer="defer"></script>
    {%- when 'product' -%}
      <script src="{{ 'main-product.js' | asset_url }}" defer="defer"></script>
      {%- liquid
        assign has_360_image = false
        for media in product.media
          if media.media_type == 'image' and media.alt == 'image-360'
            assign has_360_image = true
            break
          endif
        endfor
      -%}
      {%- if has_360_image -%}
        <script src="{{ 'js-cloudimage-360-view.min.js' | asset_url }}" defer="defer"></script>
      {%- endif -%}
    {%- when 'search' -%}
      <script src="{{ 'collection.js' | asset_url }}" defer="defer"></script>
  {%- endcase -%}
{%- endif -%}
<script defer="defer">
  var glozin_app = {
  shop: '{{ shop.permanent_domain }}',
  domain: '{{ shop.domain }}',
  {%- if admin_vi == true -%}
    lic: '{{ settings.purchase_code }}',
    action: '{{ settings.purchase_code_action }}',
    _e: '{{ encoded_license }}',
    _s: '{{ license_salt }}',
  {%- endif -%}
  mode: '{%- if admin_vi == true -%}admin{% else %}front{%- endif -%}',
  };
</script>
