<script>
  window.diyvapeDeferredAssets = window.diyvapeDeferredAssets || [];
  (function () {
    if (window.diyvapeDeferredLoaderReady) return;

    window.diyvapeDeferredLoaderReady = true;

    var assets = window.diyvapeDeferredAssets;
    var pageType = {{ request.page_type | json }};
    var requested = false;
    var scriptChain = Promise.resolve();
    var loaded = {};
    var loadedPromises = {};
    var visualStylePromises = [];
    var visualReady = false;
    var visualReadyTimer = null;
    var originalPush = assets.push.bind(assets);
    var originalAppendChild = Node.prototype.appendChild;
    var originalInsertBefore = Node.prototype.insertBefore;
    var blockedDynamicAssets = [];
    var dynamicAssetsAllowed = false;
    var releasingDynamicAssets = false;
    var postGateDynamicAssetsScheduled = false;
    var releasedDynamicGroups = {};

    function getNodeUrl(node) {
      if (!node || node.nodeType !== 1) return '';
      var tagName = node.tagName;
      if (tagName === 'SCRIPT') return node.src || '';
      if (tagName === 'LINK') return node.href || '';
      return '';
    }

    function getDeferredDynamicGroup(url) {
      var value = String(url || '').toLowerCase();
      if (!value) return '';

      if (
        value.indexOf('rapi-487') !== -1 ||
        value.indexOf('rappi-front.') !== -1 ||
        value.indexOf('rapi-front.') !== -1
      ) {
        return 'rapi';
      }

      if (
        value.indexOf('mercadopago-pf-app') !== -1 ||
        value.indexOf('generate-meli-session-id') !== -1 ||
        value.indexOf('mercadopago.com') !== -1 ||
        value.indexOf('melidata') !== -1
      ) {
        return 'commerce';
      }

      if (
        value.indexOf('judgeme-505') !== -1 ||
        value.indexOf('judge.me') !== -1 ||
        value.indexOf('cdnwidget.judge.me') !== -1
      ) {
        return 'reviews';
      }

      if (
        value.indexOf('googletagmanager.com/gtag/js') !== -1 ||
        value.indexOf('/wpm/') !== -1 ||
        value.indexOf('web-pixels-manager') !== -1 ||
        value.indexOf('splmn-shopify-prod') !== -1
      ) {
        return 'analytics';
      }

      return '';
    }

    function shouldReleaseDynamicAsset(entry, group) {
      if (!entry) return false;
      if (group && entry.group !== group) return false;
      /* Rapi y Judge.me sólo tienen sentido en PDP. En cualquier otra página
         los seguimos bloqueando incluso después del age gate — el merchant
         confirmó que Judge.me solo se usa en product page y Rapi también. */
      if (entry.group === 'rapi' && pageType !== 'product') return false;
      if (entry.group === 'reviews' && pageType !== 'product') return false;
      return true;
    }

    function blockDynamicAsset(parent, node, referenceNode) {
      var url = getNodeUrl(node);
      var group = getDeferredDynamicGroup(url);
      if (!group) return false;
      if (group === 'rapi' && pageType !== 'product') return true;
      if (group === 'reviews' && pageType !== 'product') return true;
      if (releasingDynamicAssets || dynamicAssetsAllowed || isAgeVerified()) return false;
      blockedDynamicAssets.push({
        parent: parent,
        node: node,
        referenceNode: referenceNode,
        url: url,
        group: group
      });
      return true;
    }

    function appendDynamicAsset(entry) {
      var parent = entry.parent || document.head || document.documentElement;
      if (entry.referenceNode && entry.referenceNode.parentNode === parent) {
        originalInsertBefore.call(parent, entry.node, entry.referenceNode);
      } else {
        originalAppendChild.call(parent, entry.node);
      }
    }

    function releaseDynamicAssets(group) {
      dynamicAssetsAllowed = true;
      if (group) releasedDynamicGroups[group] = true;
      if (!blockedDynamicAssets.length) return;
      releasingDynamicAssets = true;
      var remaining = [];
      blockedDynamicAssets.splice(0).forEach(function (entry) {
        if (group && entry.group !== group) {
          remaining.push(entry);
          return;
        }
        if (shouldReleaseDynamicAsset(entry, group)) appendDynamicAsset(entry);
      });
      blockedDynamicAssets = remaining;
      releasingDynamicAssets = false;
    }

    function runWhenIdle(callback, timeout) {
      if ('requestIdleCallback' in window) {
        window.requestIdleCallback(callback, { timeout: timeout || 3000 });
      } else {
        window.setTimeout(callback, timeout || 1);
      }
    }

    function closestTarget(event, selector) {
      var target = event && event.target;
      if (target && target.nodeType !== 1) target = target.parentElement;
      return target && target.closest ? target.closest(selector) : null;
    }

    function releaseCommerceAssets() {
      releaseDynamicAssets('commerce');
    }

    function scheduleCommerceAssets() {
      if (releasedDynamicGroups.commerce) return;
      var released = false;
      var selector = [
        'a[href*="/cart"]',
        'a[href*="/checkout"]',
        'button[name="add"]',
        'button[name="checkout"]',
        '[data-add-to-cart]',
        '[data-cart]',
        '.shopify-payment-button',
        '.product-form__submit',
        'cart-drawer',
        'cart-items'
      ].join(',');

      var release = function () {
        if (released) return;
        released = true;
        document.removeEventListener('click', onClick, true);
        document.removeEventListener('submit', onSubmit, true);
        releaseCommerceAssets();
      };

      var onClick = function (event) {
        if (closestTarget(event, selector)) release();
      };

      var onSubmit = function (event) {
        var target = event && event.target;
        var action = target && target.getAttribute ? target.getAttribute('action') || '' : '';
        if (action.indexOf('/cart') !== -1 || closestTarget(event, 'form[action*="/cart"]')) release();
      };

      document.addEventListener('click', onClick, true);
      document.addEventListener('submit', onSubmit, true);
      runWhenIdle(release, 10000);
    }

    function scheduleReviewAssets() {
      if (releasedDynamicGroups.reviews) return;
      var release = function () {
        releaseDynamicAssets('reviews');
      };
      var reviewRoot = document.querySelector('#judgeme_product_reviews, .jdgm-widget, [class*="jdgm-"]');
      if (reviewRoot && 'IntersectionObserver' in window) {
        var observer = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting || entry.intersectionRatio > 0) {
              observer.disconnect();
              release();
            }
          });
        }, { rootMargin: '500px 0px' });
        observer.observe(reviewRoot);
      } else {
        runWhenIdle(release, 6000);
      }
    }

    function scheduleAnalyticsAssets() {
      runWhenIdle(function () {
        releaseDynamicAssets('analytics');
      }, 2000);
    }

    function releasePostGateDynamicAssets() {
      if (postGateDynamicAssetsScheduled) return;
      postGateDynamicAssetsScheduled = true;
      releaseDynamicAssets('rapi');
      scheduleCommerceAssets();
      scheduleReviewAssets();
      scheduleAnalyticsAssets();
    }

    function parseVerified(raw) {
      if (!raw) return false;
      try {
        var parsed = JSON.parse(decodeURIComponent(raw));
        return Boolean(parsed && parsed.verified && parsed.dob && parsed.id);
      } catch (error) {
        try {
          var fallback = JSON.parse(raw);
          return Boolean(fallback && fallback.verified && fallback.dob && fallback.id);
        } catch (innerError) {
          return false;
        }
      }
    }

    function getCookie(name) {
      var prefix = name + '=';
      var parts = document.cookie ? document.cookie.split(';') : [];
      for (var i = 0; i < parts.length; i += 1) {
        var value = parts[i].trim();
        if (value.indexOf(prefix) === 0) return value.slice(prefix.length);
      }
      return '';
    }

    function isAgeVerified() {
      if (document.documentElement.classList.contains('age-gate-verified')) return true;
      if (parseVerified(getCookie('age_verified_diyvape'))) return true;
      try {
        return parseVerified(localStorage.getItem('age_verified_diyvape'));
      } catch (error) {
        return false;
      }
    }

    /* Interceptamos appendChild/insertBefore en estos casos:
       1) Usuario NO verificado (cualquier página) — para bloquear todo hasta age gate.
       2) Página != product (incluso para verified) — para bloquear reviews y rapi en
          collection/home/search donde no aportan valor pero sí pesan.
       Skip total para verified-en-PDP: preserva el win de v2 (cero overhead en el
       caso de mayor tráfico, los usuarios recurrentes viendo producto). */
    if (!isAgeVerified() || pageType !== 'product') {
      Node.prototype.appendChild = function (node) {
        if (blockDynamicAsset(this, node, null)) return node;
        return originalAppendChild.call(this, node);
      };

      Node.prototype.insertBefore = function (node, referenceNode) {
        if (blockDynamicAsset(this, node, referenceNode)) return node;
        return originalInsertBefore.call(this, node, referenceNode);
      };
    }

    function markVisualReady() {
      if (visualReady) return;
      visualReady = true;
      document.documentElement.classList.add('diyvape-deferred-visual-ready');
      window.dispatchEvent(new CustomEvent('diyvape:deferred-visual-ready'));
    }

    function waitForVisualStyles() {
      if (visualReady) return;
      if (!visualStylePromises.length) {
        markVisualReady();
        return;
      }

      Promise.all(visualStylePromises.slice()).then(markVisualReady);

      if (!visualReadyTimer) {
        visualReadyTimer = window.setTimeout(markVisualReady, 3000);
      }
    }

    function isVisualStyle(asset) {
      return asset && asset.type === 'style' && asset.visual !== false;
    }

    function loadStyle(asset) {
      if (!asset || !asset.href) return Promise.resolve();
      if (loaded[asset.href]) return loadedPromises[asset.href] || Promise.resolve();
      loaded[asset.href] = true;

      loadedPromises[asset.href] = new Promise(function (resolve) {
        var link = document.createElement('link');
        link.rel = 'stylesheet';
        link.href = asset.href;
        link.media = asset.media || 'all';
        link.dataset.diyvapeDeferred = 'true';
        link.onload = resolve;
        link.onerror = resolve;
        document.head.appendChild(link);
      });

      return loadedPromises[asset.href];
    }

    function loadScript(asset) {
      if (!asset || !asset.src) return Promise.resolve();
      if (loaded[asset.src]) return loadedPromises[asset.src] || Promise.resolve();
      loaded[asset.src] = true;

      loadedPromises[asset.src] = new Promise(function (resolve) {
        var script = document.createElement('script');
        script.src = asset.src;
        script.async = false;
        script.defer = true;
        if (asset.module) script.type = 'module';
        if (asset.id) script.id = asset.id;
        script.dataset.diyvapeDeferred = 'true';
        script.onload = resolve;
        script.onerror = resolve;
        document.head.appendChild(script);
      });

      return loadedPromises[asset.src];
    }

    function queueScript(asset) {
      scriptChain = scriptChain.then(function () {
        return loadScript(asset);
      });
      return scriptChain;
    }

    function loadAsset(asset) {
      if (!asset) return;
      if (asset.type === 'style') {
        return loadStyle(asset);
      }
      if (asset.type === 'script') {
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', function () {
            queueScript(asset);
          }, { once: true });
          return Promise.resolve();
        }
        return queueScript(asset);
      }
      return Promise.resolve();
    }

    function loadDeferredAssets() {
      if (requested) return scriptChain;
      requested = true;
      document.documentElement.classList.add('diyvape-deferred-assets-requested');

      assets.slice().forEach(function (asset) {
        var assetPromise = loadAsset(asset);
        if (isVisualStyle(asset)) visualStylePromises.push(assetPromise || Promise.resolve());
      });

      waitForVisualStyles();

      scriptChain.then(function () {
        document.documentElement.classList.add('diyvape-deferred-assets-loaded');
        window.dispatchEvent(new CustomEvent('diyvape:deferred-assets-loaded'));
      });

      return scriptChain;
    }

    assets.push = function () {
      var incoming = Array.prototype.slice.call(arguments);
      var result = originalPush.apply(assets, incoming);
      if (requested) {
        incoming.forEach(function (asset) {
          var assetPromise = loadAsset(asset);
          if (!visualReady && isVisualStyle(asset)) {
            visualStylePromises.push(assetPromise || Promise.resolve());
            waitForVisualStyles();
          }
        });
      }
      return result;
    };

    window.diyvapeLoadDeferredAssets = loadDeferredAssets;

    window.addEventListener('diyvape:age-verified', function () {
      loadDeferredAssets();
      releasePostGateDynamicAssets();
    }, { once: true });
    document.addEventListener('diyvape:age-verified', function () {
      loadDeferredAssets();
      releasePostGateDynamicAssets();
    }, { once: true });

    if (isAgeVerified()) {
      window.setTimeout(function () {
        loadDeferredAssets();
        releasePostGateDynamicAssets();
      }, 0);
    } else {
      document.addEventListener('DOMContentLoaded', function () {
        var gate = document.querySelector('age-verification-gate');
        if (!gate || !gate.classList.contains('active') || gate.getAttribute('aria-hidden') === 'true') {
          loadDeferredAssets();
          releasePostGateDynamicAssets();
        }
      }, { once: true });
    }
  })();
</script>
