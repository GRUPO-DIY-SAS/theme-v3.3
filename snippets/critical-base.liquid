{% comment %}
  snippets/critical-base.liquid
  ──────────────────────────────
  Versión INLINE del antiguo assets/critical-base.css (5.3 KB).
  Se renderiza como <style> directamente en el <head> via {% style %}
  para eliminar un render-blocking HTTP request en el primer paint.

  Si necesitas modificar las reglas, edita ACÁ. El archivo
  assets/critical-base.css se conserva como backup pero ya no se
  fetcha.
{% endcomment %}
{% style %}
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    -webkit-tap-highlight-color: transparent;
  }

  html {
    min-height: 100%;
    margin: 0;
    padding: 0;
    overflow-x: hidden;
    font-size: 62.5%;
    -webkit-text-size-adjust: 100%;
  }

  body {
    min-height: 100vh;
    margin: 0;
    display: flex;
    flex-direction: column;
    font-family: var(--body-font), sans-serif;
    font-size: var(--body-font-size, 1.4rem);
    font-weight: var(--body-weight, 400);
    line-height: var(--body-line-height, 1.714);
    color: var(--color-text);
    background: var(--color-background);
    overflow-wrap: break-word;
    text-rendering: optimizeSpeed;
    -webkit-font-smoothing: antialiased;
  }

  main {
    display: block;
    flex: 1 0 auto;
  }

  img,
  video {
    max-width: 100%;
    height: auto;
  }

  a {
    color: var(--color-link);
    text-decoration: none;
  }

  button,
  input,
  select,
  textarea {
    font: inherit;
  }

  :where(.container, .fluid_container) {
    width: 100%;
    margin-inline: auto;
    padding-left: var(--bs-gutter-x, 1.5rem);
    padding-right: var(--bs-gutter-x, 1.5rem);
  }

  @media (min-width: 1200px) {
    .container {
      max-width: calc(var(--page-width) + var(--bs-gutter-x, 1.5rem) * 2);
    }

    .fluid_container {
      max-width: calc(var(--fluid-container-width) + var(--bs-gutter-x, 1.5rem) * 2);
    }
  }

  :where(h1, h2, h3, h4, h5, h6, .h1, .h2, .h3, .h4, .h5, .h6, .h0, .heading) {
    margin-block: 0.7em;
    color: var(--color-heading);
    font-family: var(--heading-font), sans-serif;
    font-weight: var(--heading-weight, 600);
    line-height: 1.15;
    text-transform: var(--heading-text-transform);
  }

  .hidden { display: none; }
  .hidden-important { display: none !important; }
  .block { display: block; }
  .flex { display: flex; }
  .inline-flex { display: inline-flex; }
  .relative { position: relative; }
  .absolute { position: absolute; }
  .fixed { position: fixed; }
  .inset-0 { inset: 0; }
  .inset-x-0 { left: 0; right: 0; }
  .w-full { width: 100%; }
  .h-full { height: 100%; }
  .overflow-hidden { overflow: hidden; }
  .align-center { align-items: center; }
  .content-center { align-items: center; justify-content: center; }
  .justify-center { justify-content: center; }
  .text-center { text-align: center; }
  .z-1 { z-index: 1; }
  .z-15 { z-index: 15; }

  .gradient {
    background: var(--gradient-background, var(--color-background));
  }

  .section {
    padding-top: calc(var(--section-pt, 0) * 1px);
    padding-bottom: calc(var(--section-pb, 0) * 1px);
  }

  [style*="--aspect-ratio"]::before {
    content: "";
    display: block;
    padding-top: calc(100% / (var(--aspect-ratio)));
  }

  [style*="--aspect-ratio"] {
    position: relative;
    overflow: hidden;
  }

  [style*="--aspect-ratio-mb"]::before {
    padding-top: calc(100% / (var(--aspect-ratio-mb)));
  }

  :where([style*="--aspect-ratio"] > :is(*:first-child, .secondary-image)),
  :where([style*="--aspect-ratio"]) > picture > *,
  :where([style*="--aspect-ratio"]) motion-element img,
  picture {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .h-custom {
    min-height: var(--height);
  }

  @media (min-width: 992px) {
    .h-custom {
      min-height: var(--height-desktop);
    }
  }

  .sec__inner .banner__media :is(picture, source, img, video),
  .sec__video video,
  .video-foreground iframe,
  .video-foreground,
  video.slideshow {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .banner__media {
    display: block;
  }

  .overlay-bg::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-color: var(--overlay-bg);
    opacity: calc(var(--overlay-opacity, 0) / 100);
  }

  .visually-hidden {
    position: absolute !important;
    width: 1px !important;
    height: 1px !important;
    padding: 0 !important;
    margin: -1px !important;
    overflow: hidden !important;
    clip: rect(0, 0, 0, 0) !important;
    white-space: nowrap !important;
    border: 0 !important;
  }

  /* Preload-page overlay (anti-FOUC): cubre la página con white screen
     hasta que deferred-assets-loader complete. Inline aquí (no en critical.css
     que es deferida) para que aplique INMEDIATAMENTE en primer paint. */
  preload-page.preload-page,
  .preload-page {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #ffffff;
    pointer-events: none;
    opacity: 1;
    visibility: visible;
    transition: opacity 0.25s ease-out;
  }
  /* Spinner del preload (option "dot"). El CSS está también en theme.css
     pero es deferida; aquí lo inline para que el spinner aparezca animado
     desde el primer paint sin esperar theme.css. */
  .preload-screen-spinner {
    --loading-size: 80px;
    --loading-color: #bbbbbb;
    animation: pageTransitionSpinner 1.5s linear infinite;
    width: var(--loading-size);
    height: var(--loading-size);
    border-radius: 50%;
    box-shadow: 0 2px 0 0 var(--loading-color);
    transform-origin: calc(var(--loading-size) / 2) calc(var(--loading-size) / 2 + 1px);
  }
  @keyframes pageTransitionSpinner {
    0%   { transform: rotate3d(0, 0, 1, 0deg); }
    25%  { transform: rotate3d(0, 0, 1, 90deg); }
    50%  { transform: rotate3d(0, 0, 1, 180deg); }
    75%  { transform: rotate3d(0, 0, 1, 270deg); }
    100% { transform: rotate3d(0, 0, 1, 360deg); }
  }

  /* FOUC prevention: anti-flash de contenido sin estilos.
     Después del age gate, CSS visual y scripts se cargan por rutas separadas.
     Revelamos header/main cuando el CSS visual está listo, no cuando termina
     toda la cadena de JS diferido. Esto evita que scripts no críticos retrasen
     LCP/Speed Index. */

  /* Horizontal nav: depende de navigation.css, que se inyecta desde
     horizontal-menu.liquid. Lo protegemos con una señal propia para no atarlo
     a todos los scripts diferidos. */
  html:not(.diyvape-nav-css-loaded) .navigation.horizontal {
    visibility: hidden !important;
  }

  /* Header completo: hide hasta que el CSS visual cargue. Sin theme.css,
     el header renderea sin flex/grid → logo desalineado, icons flotando,
     menu como lista vertical con bullets. El preload-page (z:100) cubre
     visualmente pero también añadimos visibility:hidden por seguridad. */
  html:not(.diyvape-deferred-visual-ready) .header,
  html:not(.diyvape-deferred-visual-ready) .header__inner,
  html:not(.diyvape-deferred-visual-ready) .top-bar,
  html:not(.diyvape-deferred-visual-ready) shopify-section-header {
    visibility: hidden !important;
  }

  /* Scrolling text / announcement marquees: renderean en bucle si no hay
     CSS para constreñirlas. Hide hasta que theme.css cargue. */
  html:not(.diyvape-deferred-visual-ready) .scrolling-text,
  html:not(.diyvape-deferred-visual-ready) scrolling-text,
  html:not(.diyvape-deferred-visual-ready) [class*="marquee"] {
    visibility: hidden !important;
  }

  /* Main content puede tener layout broken sin theme.css. Hide hasta que
     deferred CSS cargue. El preload-page (z:100) cubre, pero por si acaso. */
  html:not(.diyvape-deferred-visual-ready) main {
    visibility: hidden !important;
  }

  /* Critical: ocultar el navigation drawer mobile hasta que navigation.css
     cargue (deferido tras age-gate). Sin esto, el drawer aparece visible
     en el primer paint cuando el HTML renderiza antes que la CSS deferida. */
  .navigation.mobile {
    opacity: 0;
    pointer-events: none;
    transform: translateX(-101%);
    visibility: hidden;
  }
  .nav-open .navigation.mobile {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(0);
    visibility: visible;
  }
  html.diyvape-suppress-nav .navigation.mobile {
    opacity: 0 !important;
    pointer-events: none !important;
    transform: translateX(-101%) !important;
    visibility: hidden !important;
  }

  /* Critical: ocultar mega-menu submenus en MOBILE solamente (donde
     Lighthouse mide). En mobile el mega-menu horizontal NO se muestra
     (es block-1025 = desktop only), pero sin navigation.css cargada las
     imágenes de productos destacados dentro de .submenu aparecen renderizadas
     en DOM y se vuelven phantom LCPs (12s en Lighthouse).
     Excluimos cuando el drawer mobile está abierto (html.nav-open) o cuando
     un parent tiene .is-open explícito. Desktop sin cambios para no romper
     hover/click del mega menu. */
  @media (max-width: 1024.98px) {
    .submenu:not(.submenu-vertical),
    .sub-children-menu {
      display: none;
    }
    html.nav-open .submenu:not(.submenu-vertical),
    html.nav-open .sub-children-menu,
    .is-open + .submenu,
    .is-open + .sub-children-menu,
    .menu-parent.visible .submenu:not(.submenu-vertical) {
      display: block;
    }
  }

  cart-notification .minicart__wrapper:not(.open) {
    pointer-events: none;
    visibility: hidden;
  }

  html.diyvape-suppress-minicart cart-notification,
  html.diyvape-suppress-minicart .overlayminicart::after {
    opacity: 0 !important;
    pointer-events: none !important;
    visibility: hidden !important;
  }

  html.diyvape-suppress-minicart cart-notification .minicart__wrapper {
    opacity: 0 !important;
    pointer-events: none !important;
    visibility: hidden !important;
  }

  html.diyvape-suppress-search #search-form,
  html.diyvape-suppress-search .popup-search,
  html.diyvape-suppress-search .overlay_search {
    opacity: 0 !important;
    pointer-events: none !important;
    visibility: hidden !important;
  }

  cart-notification .minicart__wrapper.bls__drawer {
    position: fixed;
    top: 0;
    bottom: 0;
    width: 100%;
    max-width: var(--drawer-width, 48rem);
    height: 100%;
  }

  cart-notification .minicart__wrapper.bls__drawer.left {
    right: 0;
    transform: translateX(100%);
  }

  html.diyvape-suppress-minicart cart-notification .minicart__wrapper.bls__drawer.left {
    transform: translateX(100%) !important;
  }

  cart-notification .minicart__wrapper.bls__drawer.right {
    left: 0;
    transform: translateX(-100%);
  }

  html.diyvape-suppress-minicart cart-notification .minicart__wrapper.bls__drawer.right {
    transform: translateX(-100%) !important;
  }

  .open-drawer cart-notification .minicart__wrapper.bls__drawer.open {
    transform: translateX(0);
    visibility: visible;
  }
{% endstyle %}
