{% liquid
  assign theme_st = settings
  assign enable_preload = theme_st.enable_preload
  assign preload_page = theme_st.preload_page
%}
{% if enable_preload %}
  <preload-page
    {% if preload_page == 'background' %}
      style="background-color: #fff"
    {% endif %}
    class="preload-page fixed bg-white pointer-none inset-0 flex content-center"
  >
    {% if preload_page == 'dot' %}
      <span class="preload-screen-spinner"></span>
    {% elsif preload_page == 'spin' %}
      <span class="preload-screen-loading-bar"></span>
    {% endif %}
  </preload-page>
{% endif %}

<script>
  (function () {
    var preload = document.querySelector('preload-page');
    if (!preload) return;

    var hidden = false;
    function hidePreload() {
      if (hidden) return;
      hidden = true;
      /* CSS transition controlled by inline styles for instant effect
         even if external CSS hasn't loaded yet */
      preload.style.transition = 'opacity 0.25s ease-out';
      preload.style.opacity = '0';
      window.setTimeout(function () {
        preload.style.visibility = 'hidden';
        preload.style.pointerEvents = 'none';
      }, 260);
    }

    /* Hide on deferred-assets-loaded event: this fires when navigation.css,
       theme.css and other deferred CSS have been requested + scripts queued.
       That's the right moment — page is styled and ready. */
    window.addEventListener('diyvape:deferred-assets-loaded', hidePreload, { once: true });

    /* Fallback 1: if no age gate (user already verified), the loader fires
       on DOMContentLoaded. Hide preload then too. */
    if (document.documentElement.classList.contains('diyvape-deferred-assets-loaded')) {
      hidePreload();
    }

    /* Fallback 2: if 5s pass without event (something stuck), force hide.
       Better to show possibly-FOUC page than block forever. */
    window.setTimeout(hidePreload, 5000);
  })();
</script>
