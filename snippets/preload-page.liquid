{% liquid
  assign theme_st = settings
  assign enable_preload = theme_st.enable_preload
  assign preload_page = theme_st.preload_page
%}
{% if enable_preload %}
  <preload-page
    {% if preload_page == 'background' %}
      style="background-color: #fff"
    {% endif %}
    class="preload-page fixed bg-white pointer-none inset-0 flex content-center"
  >
    {% if preload_page == 'dot' %}
      <span class="preload-screen-spinner"></span>
    {% elsif preload_page == 'spin' %}
      <span class="preload-screen-loading-bar"></span>
    {% endif %}
  </preload-page>
{% endif %}

<script>
  (function () {
    var preload = document.querySelector('preload-page');
    if (!preload) return;

    var hidden = false;
    var MIN_SHOW_MS = 500;
    var showStartedAt = Date.now();

    function actuallyHide() {
      if (hidden) return;
      hidden = true;
      /* CSS transition inline para que aplique aunque external CSS no haya
         cargado todavía */
      preload.style.transition = 'opacity 0.3s ease-out';
      preload.style.opacity = '0';
      window.setTimeout(function () {
        preload.style.visibility = 'hidden';
        preload.style.pointerEvents = 'none';
      }, 320);
    }

    /* Respeta MIN_SHOW_MS para evitar que el spinner desaparezca antes del
       primer paint (caso usuario verificado donde el loader fire eventos en
       microtask antes de body parse) */
    function readyToHide() {
      var elapsed = Date.now() - showStartedAt;
      var remaining = Math.max(0, MIN_SHOW_MS - elapsed);
      window.setTimeout(actuallyHide, remaining);
    }

    /* Detectar si el age gate estaba activo cuando el script corre.
       Si sí, reseteamos el timer cuando el usuario verifica edad para que
       el MIN_SHOW_MS aplique a partir del cierre del gate, no del page load. */
    var ageGate = document.querySelector('age-verification-gate');
    if (ageGate && ageGate.classList.contains('active')) {
      document.addEventListener('diyvape:age-verified', function () {
        showStartedAt = Date.now();
      }, { once: true });
    }

    /* Señal principal: deferred CSS+JS listos */
    window.addEventListener('diyvape:deferred-assets-loaded', readyToHide, { once: true });

    /* Si el evento ya disparó antes de que este script corra (usuario
       verificado con loader fired en head), aún esperamos MIN_SHOW_MS */
    if (document.documentElement.classList.contains('diyvape-deferred-assets-loaded')) {
      readyToHide();
    }

    /* Fallback hard: 6s max, force hide aunque nada haya disparado */
    window.setTimeout(actuallyHide, 6000);
  })();
</script>
