{% comment %}
  LeadConnector chat widget — DIYVAPE.CO

  PageSpeed/INP optimization: the LC bundle (and the Mulish font it pulls
  from fonts.gstatic.com, ~230KB total) is NOT loaded on initial page
  view. Instead we render a lightweight floating button (no external
  fonts, inline SVG) and only inject the LC loader on user click.

  Gated by localStorage.age_verified_diyvape (+18 compliance): the
  trigger button stays hidden until age verification passes.

  DNS/TLS to widgets.leadconnectorhq.com is pre-warmed on the first
  hover/focus of the trigger so the click→chat latency stays low without
  paying the connection cost on initial render.

  Skip loading on password template.

  @example
  {% render 'chat-widget-leadconnector' %}
{% endcomment %}

{%- unless template contains 'password' -%}
  <button
    type="button"
    id="diyvape-chat-trigger"
    class="diyvape-chat-trigger"
    aria-label="Abrir chat"
    hidden
  >
    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
    </svg>
    <span class="diyvape-chat-trigger__label">Chat</span>
  </button>

  <style>
    .diyvape-chat-trigger {
      position: fixed;
      right: 30px;
      bottom: 90px;
      z-index: 99998;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 0 18px 0 14px;
      height: 52px;
      border: 0;
      border-radius: 999px;
      background: var(--btn-primary-bg-color, #111);
      color: var(--btn-primary-color, #fff);
      font-family: inherit;
      font-size: 15px;
      font-weight: 600;
      line-height: 1;
      cursor: pointer;
      box-shadow: 0 6px 20px rgba(0, 0, 0, 0.18);
      transition: transform .2s ease, box-shadow .2s ease;
      -webkit-tap-highlight-color: transparent;
    }
    .diyvape-chat-trigger:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 24px rgba(0, 0, 0, 0.22);
    }
    .diyvape-chat-trigger:focus-visible {
      outline: 2px solid var(--btn-primary-color, #fff);
      outline-offset: 2px;
    }
    .diyvape-chat-trigger[hidden] { display: none !important; }
    .diyvape-lc-hidden-launcher {
      opacity: 0 !important;
      visibility: hidden !important;
      pointer-events: none !important;
    }
    @media (max-width: 767.98px) {
      .diyvape-chat-trigger {
        right: 16px;
        bottom: 135px;
        padding: 0;
        width: 52px;
        justify-content: center;
      }
      .diyvape-chat-trigger__label { display: none; }
    }

    /* Lift LeadConnector chat button above back-to-top once it mounts */
    chat-widget,
    chat-widget::part(button),
    #lc_text-widget,
    #lcw-chat-button,
    .lc_text-widget,
    .lc_text-widget-floating-button,
    [class*="LC_chatWidget"] {
      bottom: 90px !important;
    }
    @media (max-width: 767.98px) {
      chat-widget,
      chat-widget::part(button),
      #lc_text-widget,
      #lcw-chat-button,
      .lc_text-widget,
      .lc_text-widget-floating-button,
      [class*="LC_chatWidget"] {
        bottom: 135px !important;
      }
    }
  </style>

  <script>
    (function () {
      var AGE_KEY = 'age_verified_diyvape';
      var WIDGET_SRC = 'https://widgets.leadconnectorhq.com/loader.js';
      var WIDGET_RESOURCES = 'https://widgets.leadconnectorhq.com/chat-widget/loader.js';
      var WIDGET_ID = '69deb1a7d69ee82d8d5c665b';
      var TRIGGER_ID = 'diyvape-chat-trigger';
      var SCRIPT_ID = 'diyvape-leadconnector-widget';
      var loaded = false;
      var preconnected = false;

      function getTrigger() { return document.getElementById(TRIGGER_ID); }

      function isVerified() {
        try {
          var v = localStorage.getItem(AGE_KEY);
          return v !== null && v !== '' && v !== 'false';
        } catch (e) { return false; }
      }

      function showTriggerIfVerified() {
        if (!isVerified() || loaded) return false;
        var btn = getTrigger();
        if (btn) btn.hidden = false;
        return true;
      }

      function preconnect() {
        if (preconnected) return;
        preconnected = true;
        var l = document.createElement('link');
        l.rel = 'preconnect';
        l.href = 'https://widgets.leadconnectorhq.com';
        l.crossOrigin = '';
        document.head.appendChild(l);
      }

      function isVisibleElement(el) {
        var cs;
        try { cs = window.getComputedStyle(el); } catch (e) { return false; }
        if (cs.display === 'none' || cs.visibility === 'hidden' || Number(cs.opacity) === 0) return false;
        var rect = el.getBoundingClientRect();
        return rect.width > 0 && rect.height > 0;
      }

      function isThemeFloatingControl(el) {
        if (!el || el.id === TRIGGER_ID || el.id === SCRIPT_ID) return true;
        if (el.matches && el.matches('.diyvape-chat-trigger, .back-to-top, back-to-top')) return true;
        if (el.closest && el.closest('.diyvape-chat-trigger, .back-to-top, back-to-top')) return true;
        return false;
      }

      function hasOpenLcPanel() {
        var vw = window.innerWidth;
        var selectors =
          'chat-widget,lc-chat-widget,iframe,' +
          '[id^="lc_"],[id^="lcw-"],[id^="leadconnector"],' +
          '[class*="lc_text-widget"],[class*="LC_chatWidget"],[class*="leadconnector"],' +
          '[id*="chat-widget"],[class*="chat-widget"]';
        var nodes = document.querySelectorAll(selectors);

        for (var i = 0; i < nodes.length; i++) {
          var node = nodes[i];
          if (!node || node.id === TRIGGER_ID || !isVisibleElement(node)) continue;
          var rect = node.getBoundingClientRect();
          var name = ((node.id || '') + ' ' + (node.className || '') + ' ' + (node.src || '')).toLowerCase();
          var isLcNode = name.indexOf('leadconnector') !== -1 || name.indexOf('lc') !== -1 || name.indexOf('chat') !== -1 || node.tagName === 'CHAT-WIDGET' || node.tagName === 'LC-CHAT-WIDGET';
          var isRightPanel = vw - rect.right < Math.max(140, vw * 0.18) && rect.width >= 240 && rect.height >= 260;
          if (isLcNode && isRightPanel) return true;
        }

        return false;
      }

      function isLikelyLcLauncher(el) {
        if (!el || isThemeFloatingControl(el)) return false;
        if (el.tagName === 'SCRIPT' || el.tagName === 'STYLE' || el.tagName === 'LINK') return false;
        if (!isVisibleElement(el)) return false;

        var cs;
        try { cs = window.getComputedStyle(el); } catch (e) { return false; }
        if (cs.position !== 'fixed' && cs.position !== 'absolute') return false;

        var rect = el.getBoundingClientRect();
        var vw = window.innerWidth;
        var name = ((el.id || '') + ' ' + (el.className || '') + ' ' + (el.src || '')).toLowerCase();
        var isLcNode = name.indexOf('leadconnector') !== -1 || name.indexOf('lc') !== -1 || name.indexOf('chat') !== -1 || el.tagName === 'CHAT-WIDGET' || el.tagName === 'LC-CHAT-WIDGET' || el.tagName === 'IFRAME';
        var isCircleSize = rect.width >= 36 && rect.width <= 86 && rect.height >= 36 && rect.height <= 86 && Math.abs(rect.width - rect.height) <= 12;
        var isRightSide = vw - rect.right >= -4 && vw - rect.right <= 130;
        var text = '';
        try { text = (el.innerText || el.textContent || '').trim(); } catch (e) {}
        var hasText = text.length > 1;
        var rounded = cs.borderTopLeftRadius.indexOf('%') !== -1 || parseFloat(cs.borderTopLeftRadius) >= Math.min(rect.width, rect.height) * 0.35;

        return isLcNode && isCircleSize && isRightSide && !hasText && (rounded || el.tagName === 'IFRAME');
      }

      function toggleShadowLauncherStyle(node, hide) {
        if (!node || !node.shadowRoot) return;
        var styleId = 'diyvape-shadow-hide-launcher';
        var style = node.shadowRoot.getElementById(styleId);
        if (!hide) {
          if (style) style.remove();
          return;
        }
        if (!style) {
          style = document.createElement('style');
          style.id = styleId;
          node.shadowRoot.appendChild(style);
        }
        style.textContent =
          '[class*="launcher"],[class*="floating-button"],[class*="bubble-button"],[class*="trigger-button"]' +
          '{opacity:0!important;visibility:hidden!important;pointer-events:none!important;}';
      }

      function updateLcLauncherState() {
        var panelOpen = hasOpenLcPanel();
        var selectors =
          'chat-widget,lc-chat-widget,button,[role="button"],iframe,' +
          '[id^="lc_"],[id^="lcw-"],[id^="leadconnector"],' +
          '[class*="lc_text-widget"],[class*="LC_chatWidget"],[class*="leadconnector"],' +
          '[class*="launcher"],[class*="floating"],[class*="bubble"],[id*="chat-widget"],[class*="chat-widget"]';
        var candidates = document.querySelectorAll(selectors);

        for (var i = 0; i < candidates.length; i++) {
          var node = candidates[i];
          if (!node) continue;
          toggleShadowLauncherStyle(node, panelOpen);
          if (!isLikelyLcLauncher(node)) continue;
          node.classList.toggle('diyvape-lc-hidden-launcher', panelOpen);
        }
      }

      function liftLcWidget() {
        var isMobile = window.matchMedia('(max-width: 767.98px)').matches;
        var lift = isMobile ? 135 : 90;
        var rightOffset = isMobile ? 16 : 30;
        var SHADOW_STYLE_ID = 'diyvape-shadow-lift';
        var SHADOW_CSS =
          ':host{--lc-bottom-offset:' + lift + 'px;bottom:' + lift + 'px !important;right:' + rightOffset + 'px !important;}';

        // 1) Direct DOM elements (when LC renders in light DOM)
        var SELECTORS =
          'chat-widget,lc-chat-widget,' +
          '[id^="lc_"],[id^="lcw-"],[id^="leadconnector"],' +
          '[class*="lc_text-widget"],[class*="LC_chatWidget"],[class*="leadconnector"],' +
          '[id*="chat-widget"]';
        document.querySelectorAll(SELECTORS).forEach(function (n) {
          if (n.id === TRIGGER_ID) return;
          try {
            n.style.setProperty('bottom', lift + 'px', 'important');
            n.style.setProperty('right', rightOffset + 'px', 'important');
          } catch (e) {}
          // Pierce shadow DOM
          if (n.shadowRoot && !n.shadowRoot.getElementById(SHADOW_STYLE_ID)) {
            try {
              var s = document.createElement('style');
              s.id = SHADOW_STYLE_ID;
              s.textContent = SHADOW_CSS;
              n.shadowRoot.appendChild(s);
            } catch (e) {}
          }
        });

        // 2) Heuristic: any fixed-positioned element near the bottom-right
        //    corner that isn't ours gets lifted. Catches LC variants we
        //    can't enumerate and the "Hola..." welcome bubble.
        var vw = window.innerWidth;
        var vh = window.innerHeight;
        var bodyKids = document.body.children;
        for (var i = 0; i < bodyKids.length; i++) {
          var el = bodyKids[i];
          if (!el || el.id === TRIGGER_ID || el.id === SCRIPT_ID) continue;
          if (el.tagName === 'SCRIPT' || el.tagName === 'STYLE' || el.tagName === 'LINK') continue;
          var cs;
          try { cs = window.getComputedStyle(el); } catch (e) { continue; }
          if (cs.position !== 'fixed') continue;
          var rect = el.getBoundingClientRect();
          if (rect.width === 0 || rect.height === 0) continue;
          var nearBottom = vh - rect.bottom < 40;
          var nearRight = vw - rect.right < 80;
          if (!nearBottom || !nearRight) continue;
          try { el.style.setProperty('bottom', lift + 'px', 'important'); } catch (e) {}
        }

        updateLcLauncherState();
      }

      function injectWidget() {
        if (loaded || document.getElementById(SCRIPT_ID)) return;
        loaded = true;
        var btn = getTrigger();
        if (btn) btn.hidden = true;
        var s = document.createElement('script');
        s.id = SCRIPT_ID;
        s.src = WIDGET_SRC;
        s.setAttribute('data-resources-url', WIDGET_RESOURCES);
        s.setAttribute('data-widget-id', WIDGET_ID);
        s.async = true;
        s.defer = true;
        document.body.appendChild(s);

        // Catch LC mount via DOM mutations
        var mo = new MutationObserver(liftLcWidget);
        mo.observe(document.body, { childList: true, subtree: true });

        // Polling fallback: LC can update its launcher/panel outside the
        // body tree. This runs only after the user opens chat, so it does
        // not affect initial PageSpeed.
        var pollIv = setInterval(function () {
          liftLcWidget();
        }, 1000);
        window.addEventListener('pagehide', function () {
          clearInterval(pollIv);
          mo.disconnect();
        }, { once: true });

        // React to viewport resize (mobile/desktop swap during use)
        window.addEventListener('resize', liftLcWidget, { passive: true });
      }

      function bindTrigger() {
        var btn = getTrigger();
        if (!btn) return;
        btn.addEventListener('pointerenter', preconnect, { once: true, passive: true });
        btn.addEventListener('focus', preconnect, { once: true });
        btn.addEventListener('click', injectWidget, { once: true });
      }

      bindTrigger();
      showTriggerIfVerified();

      document.addEventListener('diyvape:age-verified', showTriggerIfVerified, { once: true });

      window.addEventListener('storage', function (e) {
        if (e.key === AGE_KEY && e.newValue) showTriggerIfVerified();
      });
    })();
  </script>
{%- endunless -%}
