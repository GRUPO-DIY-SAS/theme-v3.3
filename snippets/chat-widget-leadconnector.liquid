{% comment %}
  LeadConnector chat widget — DIYVAPE.CO

  Loads ONLY after age-gate verification (+18 compliance).
  Gated by localStorage.age_verified_diyvape set by
  blocks/ai_gen_block_3f4d556.liquid on successful DOB submit.

  INP-optimized: defers actual widget injection until first user
  interaction (scroll/click/keydown) or 4s timeout — whichever first.
  This prevents the ~200KB LeadConnector bundle from blocking the
  main thread during initial page load.

  Skip loading on password template.

  @example
  {% render 'chat-widget-leadconnector' %}
{% endcomment %}

{%- unless template contains 'password' -%}
  <script>
    (function () {
      var AGE_KEY = 'age_verified_diyvape';
      var WIDGET_SRC = 'https://widgets.leadconnectorhq.com/loader.js';
      var WIDGET_RESOURCES = 'https://widgets.leadconnectorhq.com/chat-widget/loader.js';
      var WIDGET_ID = '69deb1a7d69ee82d8d5c665b';
      var loaded = false;
      var scheduled = false;

      function isVerified() {
        try {
          var v = localStorage.getItem(AGE_KEY);
          return v !== null && v !== '' && v !== 'false';
        } catch (e) { return false; }
      }

      function injectWidget() {
        if (loaded || document.getElementById('diyvape-leadconnector-widget')) return;
        loaded = true;
        var s = document.createElement('script');
        s.id = 'diyvape-leadconnector-widget';
        s.src = WIDGET_SRC;
        s.setAttribute('data-resources-url', WIDGET_RESOURCES);
        s.setAttribute('data-widget-id', WIDGET_ID);
        s.async = true;
        s.defer = true;
        document.body.appendChild(s);
      }

      // INP fix: defer injection until user idle/interaction
      function scheduleInject() {
        if (scheduled || loaded) return;
        scheduled = true;
        var fired = false;
        var events = ['scroll','mousemove','touchstart','keydown','pointerdown'];

        function fire() {
          if (fired) return;
          fired = true;
          cleanup();
          if ('requestIdleCallback' in window) {
            requestIdleCallback(injectWidget, { timeout: 1500 });
          } else {
            setTimeout(injectWidget, 1);
          }
        }
        function cleanup() {
          events.forEach(function (ev) {
            window.removeEventListener(ev, fire, { passive: true, capture: false });
          });
          clearTimeout(fallback);
        }
        events.forEach(function (ev) {
          window.addEventListener(ev, fire, { once: true, passive: true });
        });
        // Fallback: load after 4s even with no user interaction
        var fallback = setTimeout(fire, 4000);
      }

      function tryScheduleIfVerified() {
        if (isVerified()) { scheduleInject(); return true; }
        return false;
      }

      // Initial check on script eval
      if (tryScheduleIfVerified()) return;

      // Listener for age verification event (when user submits DOB form)
      document.addEventListener('diyvape:age-verified', scheduleInject, { once: true });

      // Cross-tab sync via storage event
      window.addEventListener('storage', function (e) {
        if (e.key === AGE_KEY && e.newValue) scheduleInject();
      });

      // Watch body class changes for age gate close (legacy support)
      if (document.body) {
        var observer = new MutationObserver(function () {
          if (!document.body.classList.contains('ai-age-gate-open') && isVerified()) {
            scheduleInject();
            observer.disconnect();
          }
        });
        observer.observe(document.body, { attributes: true, attributeFilter: ['class'] });
      }

      // Poll fallback (reduced frequency: 5s × 60 attempts = 5min total)
      var attempts = 0;
      var pollIv = setInterval(function () {
        attempts++;
        if (tryScheduleIfVerified() || attempts >= 60) clearInterval(pollIv);
      }, 5000);
    })();
  </script>
{%- endunless -%}