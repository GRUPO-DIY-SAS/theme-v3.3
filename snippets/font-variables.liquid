{% liquid
  assign font_family_body = 'Instrument Sans'
  assign font_family_heading = 'Instrument Sans'

  assign theme_st = settings
  assign font_type_body = theme_st.font_type_body
  assign font_body_shopify = theme_st.font_body_system
  assign font_body_google = theme_st.font_body_google
  assign font_body_google_embed = theme_st.font_body_google_embed

  assign font_type_heading = theme_st.font_type_heading
  assign font_heading_shopify = theme_st.font_heading_system
  assign font_heading_google = theme_st.font_heading_google
  assign font_body_heading_embed = theme_st.font_body_heading_embed

  assign google_fonts_api_preconnect = '<link rel="preconnect" href="https://fonts.googleapis.com">'
  assign google_fonts_static_preconnect = '<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>'
%}

{% comment %} Start check setting font {% endcomment %}
{% if font_type_body == 'default_font' %}
  {{
    'InstrumentSans-Regular.woff2'
    | asset_url
    | preload_tag: as: 'font', type: 'font/woff2', crossorigin: 'anonymous'
  }}
  {% style %}
    @font-face {
      font-family: "Instrument Sans";
      src: url({{ 'InstrumentSans-SemiBold.woff2' | asset_url }}) format("woff2");
      font-weight: 600;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: "Instrument Sans";
      src: url({{ 'InstrumentSans-Bold.ttf' | asset_url }});
      font-weight: 700;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: "Instrument Sans";
      src: url({{ 'InstrumentSans-Medium.woff2' | asset_url }}) format("woff2");
      font-weight: 500;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: "Instrument Sans";
      src: url({{ 'InstrumentSans-Regular.woff2' | asset_url }}) format("woff2");
      font-weight: normal;
      font-style: normal;
      font-display: swap;
    }
  {% endstyle %}
{% elsif font_type_body == 'google' %}
  {% assign font_family_body = font_body_google %}
  {%- liquid
    assign font_body_google_embed_clean = font_body_google_embed | remove: google_fonts_api_preconnect | remove: google_fonts_static_preconnect
  -%}
  {%- comment -%} INP optimization: load Google Fonts CSS async (-1500ms render block) {%- endcomment -%}
  {% # theme-check-disable RemoteAsset %}
  <link rel="dns-prefetch" href="https://fonts.googleapis.com">
  {% # theme-check-disable RemoteAsset %}
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  {%- capture stylesheet_orig -%}rel="stylesheet"{%- endcapture -%}
  {%- capture stylesheet_async -%}rel="preload" as="style" onload="this.onload=null;this.rel='stylesheet'"{%- endcapture -%}
  {{ font_body_google_embed_clean | replace: stylesheet_orig, stylesheet_async }}
  <noscript>{{ font_body_google_embed_clean }}</noscript>
{% else %}
  {% liquid
    assign font_body_regular = font_body_shopify
    assign font_body_medium = font_body_shopify | font_modify: 'weight', '500'
    assign font_body_semibold = font_body_shopify | font_modify: 'weight', '600'
  %}
  {% # theme-check-disable AssetPreload %}
  <link rel="preload" as="font" href="{{ font_body_regular | font_url }}" type="font/woff2" crossorigin>
  {% # theme-check-disable AssetPreload %}
  {%- capture font_family_body -%}{{ font_body_shopify.family }}, {{ font_body_shopify.fallback_families }};{%- endcapture -%}
  {%- style -%}
    {{ font_body_regular | font_face: font_display: 'swap' }}
    {{ font_body_medium | font_face: font_display: 'swap' }}
    {{ font_body_semibold | font_face: font_display: 'swap' }}
  {%- endstyle -%}
{% endif %}

{% if font_type_heading == 'default_font' %}
  {{
    'InstrumentSans-Regular.woff2'
    | asset_url
    | preload_tag: as: 'font', type: 'font/woff2', crossorigin: 'anonymous'
  }}
  {% style %}
    @font-face {
      font-family: "Instrument Sans";
      src: url({{ 'InstrumentSans-SemiBold.woff2' | asset_url }}) format("woff2");
      font-weight: 600;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: "Instrument Sans";
      src: url({{ 'InstrumentSans-Bold.ttf' | asset_url }});
      font-weight: 700;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: "Instrument Sans";
      src: url({{ 'InstrumentSans-Medium.woff2' | asset_url }}) format("woff2");
      font-weight: 500;
      font-style: normal;
      font-display: swap;
    }
    @font-face {
      font-family: "Instrument Sans";
      src: url({{ 'InstrumentSans-Regular.woff2' | asset_url }}) format("woff2");
      font-weight: normal;
      font-style: normal;
      font-display: swap;
    }
  {% endstyle %}
{% elsif font_type_heading == 'google' %}
  {% assign font_family_heading = font_heading_google %}
  {%- liquid
    assign font_heading_google_param = font_heading_google | replace: ' ', '+'
    assign heading_font_already_loaded = false
    if font_type_body == 'google' and font_body_google_embed contains font_heading_google_param
      assign heading_font_already_loaded = true
    endif
  -%}
  {%- unless heading_font_already_loaded -%}
    {%- liquid
      assign font_body_heading_embed_clean = font_body_heading_embed | remove: google_fonts_api_preconnect | remove: google_fonts_static_preconnect
    -%}
    {%- comment -%} INP optimization: load Google Fonts CSS async (heading) {%- endcomment -%}
    {%- unless font_type_body == 'google' -%}
      {% # theme-check-disable RemoteAsset %}
      <link rel="dns-prefetch" href="https://fonts.googleapis.com">
      {% # theme-check-disable RemoteAsset %}
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    {%- endunless -%}
    {%- capture stylesheet_orig_h -%}rel="stylesheet"{%- endcapture -%}
    {%- capture stylesheet_async_h -%}rel="preload" as="style" onload="this.onload=null;this.rel='stylesheet'"{%- endcapture -%}
    {{ font_body_heading_embed_clean | replace: stylesheet_orig_h, stylesheet_async_h }}
    <noscript>{{ font_body_heading_embed_clean }}</noscript>
  {%- endunless -%}
{% else %}
  {% liquid
    assign heading_weight = theme_st.heading_font_weight | default: 600
    assign font_heading_primary = font_heading_shopify | font_modify: 'weight', heading_weight
    assign font_heading_bold = font_heading_shopify | font_modify: 'weight', '700'
  %}
  {% # theme-check-disable AssetPreload %}
  <link rel="preload" as="font" href="{{ font_heading_primary | font_url }}" type="font/woff2" crossorigin>
  {% # theme-check-disable AssetPreload %}
  {%- capture font_family_heading -%}{{ font_heading_shopify.family }}, {{ font_heading_shopify.fallback_families }};{%- endcapture -%}
  {%- style -%}
    {{ font_heading_primary | font_face: font_display: 'swap' }}
    {%- unless heading_weight == 700 -%}
      {{ font_heading_bold | font_face: font_display: 'swap' }}
    {%- endunless -%}
  {%- endstyle -%}
{% endif %}

{% liquid
  assign font_menu_family = font_family_body
  assign font_menu_type = theme_st.menu_font
  if font_menu_type == 'body_font'
    assign font_menu_family = font_family_body
  else
    assign font_menu_family = font_family_heading
  endif

  assign font_button_family = font_family_body
  assign font_button_type = theme_st.button_font
  if font_button_type == 'body_font'
    assign font_button_family = font_family_body
  else
    assign font_button_family = font_family_heading
  endif
%}
{% comment %} End check setting font {% endcomment %}

{% style %}
  :root {
    --body-font: {{ font_family_body }}, sans-serif;
    --heading-font: {{ font_family_heading }}, sans-serif;
    --menu-font: {{ font_menu_family }}, sans-serif;
    --btn-font: {{ font_button_family }}, sans-serif;
  }
{% endstyle %}
