{%- assign _cp = product.metafields['shopify--discovery--product_recommendation']['complementary_products'].value -%}
{%- assign _cd = product.metafields['custom']['compat_devices'].value -%}

<script>
if(!window.chkC){
(function(){
  var s1=[{%- if _cp.size > 0 -%}{%- for cp in _cp -%}"{{ cp.title | replace: '"', '\"' | strip }}"{% unless forloop.last %},{% endunless %}{%- endfor -%}{%- endif -%}];
  var s2=[{%- if _cd != blank -%}{%- for d in _cd -%}"{{ d | replace: '"', '\"' | strip }}"{% unless forloop.last %},{% endunless %}{%- endfor -%}{%- endif -%}];
  window.diyCompatDevs=s1.concat(s2);

  function chkC(inp){
    var v=inp.value.trim(),
        c=inp.closest('.compat'),
        r=c?c.querySelector('.compat__res'):null;
    if(!r)return;
    if(v.length<2){r.innerHTML='';return}
    var s3=(c.getAttribute('data-devs')||'').split('|').map(function(d){return d.trim()}).filter(Boolean);
    var seen={},all=[];
    window.diyCompatDevs.concat(s3).forEach(function(x){
      var k=x.toLowerCase();
      if(!seen[k]){seen[k]=true;all.push(x)}
    });
    if(!all.length){r.innerHTML='';return}
    var q=v.toLowerCase(),h='',f=0;
    all.forEach(function(x){
      if(x.toLowerCase().indexOf(q)>-1){
        h+='<div class="compat__item"><span>'+x+'</span><span class="compat__badge compat__badge--y">Compatible</span></div>';
        f++;
      }
    });
    if(!f)h='<div class="compat__item"><span>No encontrado entre los equipos compatibles</span><span class="compat__badge compat__badge--n">Consultar</span></div>';
    r.innerHTML=h;
  }
  window.chkC=chkC;
})();
}
</script>