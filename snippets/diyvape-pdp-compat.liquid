{%- assign compat_products = product.metafields['shopify--discovery--product_recommendation']['complementary_products'].value -%}
{%- assign compat_devices = product.metafields['custom']['compat_devices'].value -%}

<script>
(function(){
  var s1=[{%- if compat_products.size > 0 -%}{%- for item in compat_products -%}"{{ item.title | replace: '"', '\"' | strip }}"{% unless forloop.last %},{% endunless %}{%- endfor -%}{%- endif -%}];
  var s2=[{%- if compat_devices != blank -%}{%- for device in compat_devices -%}"{{ device | replace: '"', '\"' | strip }}"{% unless forloop.last %},{% endunless %}{%- endfor -%}{%- endif -%}];
  window.diyCompatDevs = (window.diyCompatDevs||[]).concat(s1).concat(s2);
})();
</script>