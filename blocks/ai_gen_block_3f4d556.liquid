{% doc %}
  @prompt
    Mandatory Age Verification Pop Up (Spanish). Stores JSON cookie "age_verified_diyvape" with dob + id for cart re-verification.
{% enddoc %}

{%- liquid
  assign ai_gen_id = block.id | replace: '_', '' | downcase
  assign logo_width = block.settings.logo_width
  assign logo_width_2x = logo_width | times: 2
  assign logo_height = logo_width
  if block.settings.logo != blank and block.settings.logo.aspect_ratio != blank
    assign logo_height = logo_width | divided_by: block.settings.logo.aspect_ratio | round
  endif
  assign age_gate_logo_src = ''
  if block.settings.logo != blank
    assign age_gate_logo_src = block.settings.logo | image_url: width: logo_width_2x
  endif
-%}

{%- comment -%}
  Preload del logo del age gate (LCP candidate). Lo emitimos desde el
  BLOQUE en vez de theme.liquid porque acá tenemos acceso a logo_width_2x
  dinámico — evita drift si el merchant cambia logo_width en el editor.

  URL idéntica a la del <img> de abajo → cero double-fetch. Emitirlo como
  HTML directo permite que el preload scanner lo descubra antes; la versión
  anterior lo creaba con JS y Lighthouse reportaba Load Delay alto en el LCP.
{%- endcomment -%}
{%- if age_gate_logo_src != '' -%}
  {% # theme-check-disable AssetPreload %}
  <link
    rel="preload"
    href="{{ age_gate_logo_src }}"
    as="image"
    fetchpriority="high"
    data-diyvape-age-logo-preload>
  {% # theme-check-enable AssetPreload %}
{%- endif -%}

{%- assign age_verification_css = 'age-verification.css' | asset_url -%}
<style>
  .ai-age-verify-overlay {
    position: fixed;
    inset: 0;
    z-index: 99999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    visibility: hidden;
    pointer-events: none;
    opacity: 0;
    color: var(--age-text-color, #111);
  }
  .ai-age-verify-overlay::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    background: var(--age-overlay-bg, #000);
    opacity: var(--age-overlay-opacity, 1);
  }
  .ai-age-verify-overlay.active {
    visibility: visible;
    pointer-events: auto;
    opacity: 1;
  }
  html.age-gate-verified .ai-age-verify-overlay {
    display: none !important;
  }
  .ai-age-verify-modal {
    position: relative;
    z-index: 1;
    width: min(560px, calc(100vw - 32px));
    max-height: calc(100dvh - 32px);
    overflow: auto;
    background: var(--age-modal-bg, #fff);
    color: var(--age-text-color, #111);
    border: 1px solid var(--age-modal-border, #eaeaea);
    border-radius: var(--age-modal-radius, 12px);
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.38);
    padding: 30px;
    text-align: left;
  }
  .ai-age-verify-brand {
    display: flex;
    justify-content: center;
    margin-bottom: 20px;
  }
  .ai-age-verify-logo {
    width: min(var(--age-logo-width, 150px), 70vw);
    height: auto;
  }
  .ai-age-verify-header {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 16px;
    align-items: start;
    padding: 18px;
    border: 1px solid var(--age-modal-border, #eaeaea);
    border-radius: max(calc(var(--age-modal-radius, 12px) - 6px), 10px);
  }
  .ai-age-verify-badge {
    width: 54px;
    height: 54px;
    border-radius: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--age-badge-bg, #111);
    color: var(--age-badge-color, #fff);
  }
  .ai-age-verify-kicker {
    margin: 0 0 6px;
    color: var(--age-accent, #c8102e);
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .ai-age-verify-title {
    margin: 0;
    color: var(--age-text-color, #111);
    font-size: var(--age-heading-size, 28px);
    line-height: 1.1;
  }
  .ai-age-verify-text {
    margin-top: 10px;
    font-size: var(--age-text-size, 15px);
    line-height: 1.5;
  }
  .ai-age-verify-actions {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-top: 18px;
  }
  .ai-age-verify-btn,
  .ai-age-verify-submit,
  .ai-age-verify-submit-no {
    min-height: 48px;
    border-radius: var(--age-button-radius, 10px);
    font-size: var(--age-button-size, 15px);
    font-weight: 800;
    cursor: pointer;
  }
  .ai-age-verify-btn-yes,
  .ai-age-verify-submit {
    border: 1px solid var(--age-yes-bg, #111);
    background: var(--age-yes-bg, #111);
    color: var(--age-yes-color, #fff);
  }
  .ai-age-verify-btn-no,
  .ai-age-verify-submit-no {
    border: 1px solid var(--age-no-border, #d0d0d0);
    background: var(--age-no-bg, #ebebeb);
    color: var(--age-no-color, #111);
  }
  .ai-age-verify-note {
    margin-top: 14px;
    color: rgba(17, 17, 17, 0.72);
    font-size: 13px;
    line-height: 1.45;
    text-align: center;
  }
  .ai-age-verify-formwrap[hidden],
  .ai-age-verify-blocked[hidden],
  .ai-age-verify-editor-trigger {
    display: none;
  }
  body.ai-age-gate-open {
    overflow: hidden;
    position: fixed;
    width: 100%;
    top: var(--scroll-y, 0px);
  }
  @media (max-width: 749px) {
    .ai-age-verify-overlay {
      padding: 16px;
    }
    .ai-age-verify-modal {
      width: min(100%, 520px);
      padding: 24px 18px 20px;
    }
    .ai-age-verify-header {
      grid-template-columns: 1fr;
      text-align: center;
      padding: 16px 14px;
    }
    .ai-age-verify-badge {
      margin: 0 auto;
    }
    .ai-age-verify-actions {
      grid-template-columns: 1fr;
      gap: 10px;
    }
  }
</style>
{% # theme-check-disable AssetPreload %}
<link rel="preload" href="{{ age_verification_css }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
<noscript>{{ 'age-verification.css' | asset_url | stylesheet_tag }}</noscript>
<script>
  /* Click buffer: con critical-base.css inline el HTML renderiza más rápido
     que la carga del age-verification.js (defer). Esto hacía que el primer
     click en "Sí soy mayor de 18" se perdiera porque el handler aún no
     estaba registrado. Buffereamos clicks hasta que el custom element se
     haya upgrade-eado y re-disparamos. */
  (function () {
    if (window.__diyvapeAgeClickBuffer) return;
    window.__diyvapeAgeClickBuffer = true;
    var pending = [];
    var replayBufferedClick = function (entry) {
      if (!entry || !entry.gate) return;
      if (entry.action === 'yes' && typeof entry.gate.showForm === 'function') {
        entry.gate.showForm();
      }
      if (entry.action === 'no' && typeof entry.gate.showBlocked === 'function') {
        entry.gate.showBlocked();
      }
    };
    document.addEventListener('click', function (e) {
      var btn = e.target.closest && e.target.closest('[data-action="yes"], [data-action="no"]');
      if (!btn) return;
      var gate = btn.closest('age-verification-gate');
      if (!gate) return;
      /* Si el custom element ya está hidratado, deja pasar el click normal */
      if (typeof gate.showForm === 'function' || typeof gate.showBlocked === 'function') return;
      /* No upgraded yet — bufferear y re-disparar al cargar */
      e.preventDefault();
      e.stopPropagation();
      pending.push({
        action: btn.getAttribute('data-action'),
        gate: gate
      });
      var iv = setInterval(function () {
        if (typeof gate.showForm === 'function' || typeof gate.showBlocked === 'function') {
          clearInterval(iv);
          while (pending.length) replayBufferedClick(pending.shift());
        }
      }, 30);
      setTimeout(function () { clearInterval(iv); }, 5000);
    }, true);
  })();
</script>
<script src="{{ 'age-verification.js' | asset_url }}" defer="defer"></script>

<age-verification-gate
  id="AgeVerification-{{ ai_gen_id }}"
  class="ai-age-verify-overlay active"
  role="dialog"
  aria-modal="true"
  aria-hidden="false"
  aria-labelledby="AgeVerifyTitle-{{ ai_gen_id }}"
  style="
    --age-overlay-bg: {{ block.settings.overlay_bg_color }};
    --age-overlay-opacity: {{ block.settings.overlay_opacity }};
    --age-modal-bg: {{ block.settings.modal_background }};
    --age-modal-border: {{ block.settings.modal_border_color }};
    --age-accent: {{ block.settings.accent_color }};
    --age-text-color: {{ block.settings.text_color }};
    --age-heading-size: {{ block.settings.heading_size }}px;
    --age-text-size: {{ block.settings.text_size }}px;
    --age-modal-radius: {{ block.settings.border_radius }}px;
    --age-badge-bg: {{ block.settings.badge_bg }};
    --age-badge-color: {{ block.settings.badge_icon_color }};
    --age-yes-bg: {{ block.settings.yes_button_bg }};
    --age-yes-hover-bg: {{ block.settings.yes_button_hover_bg }};
    --age-yes-color: {{ block.settings.yes_button_text_color }};
    --age-no-bg: {{ block.settings.no_button_bg }};
    --age-no-hover-bg: {{ block.settings.no_button_hover_bg }};
    --age-no-color: {{ block.settings.no_button_text_color }};
    --age-no-border: {{ block.settings.no_button_border }};
    --age-submit-bg: {{ block.settings.submit_button_bg }};
    --age-submit-hover-bg: {{ block.settings.submit_button_hover_bg }};
    --age-submit-color: {{ block.settings.submit_button_text_color }};
    --age-button-size: {{ block.settings.button_text_size }}px;
    --age-button-radius: {{ block.settings.button_border_radius }}px;
    --age-input-bg: {{ block.settings.input_background }};
    --age-input-border: {{ block.settings.input_border_color }};
    --age-input-focus: {{ block.settings.input_focus_color }};
    --age-input-radius: {{ block.settings.input_border_radius }}px;
    --age-error-color: {{ block.settings.error_color }};
    --age-logo-width: {{ logo_width }}px;
  "
  data-cookie-name="{{ block.settings.cookie_name | escape }}"
  data-cookie-days="{{ block.settings.cookie_duration }}"
  data-cookie-domain="{{ block.settings.cookie_domain | escape }}"
  data-editor-mode-behavior="{{ block.settings.editor_mode_behavior }}"
  data-cookie-persistence="{{ block.settings.cookie_persistence }}"
  data-cookie-hours="{{ block.settings.cookie_hours }}"
  data-cookie-days-v2="{{ block.settings.cookie_days_v2 }}"
  data-cookie-custom-value="{{ block.settings.cookie_custom_value }}"
  data-cookie-custom-unit="{{ block.settings.cookie_custom_unit }}"
  data-cart-sync-enabled="{{ block.settings.cart_sync_enabled }}"
  data-cart-attr-prefix="{{ block.settings.cart_attr_prefix | escape }}"
  data-order-note-enabled="{{ block.settings.order_note_enabled }}"
  data-order-note-template="{{ block.settings.order_note_template | escape }}"
  data-age-error-message="{{ block.settings.age_error_message | strip_html | escape }}"
  data-id-error-message="{{ block.settings.id_error_message | strip_html | escape }}"
  data-cookie-error-message="No se pudo guardar la cookie en este navegador. Se guardó un respaldo local."
  {{ block.shopify_attributes }}
>
  <div class="ai-age-verify-modal" data-age-modal tabindex="-1">
    {%- if block.settings.logo != blank -%}
      <div class="ai-age-verify-brand">
        <img
          class="ai-age-verify-logo"
          src="{{ block.settings.logo | image_url: width: logo_width_2x }}"
          alt="{{ shop.name | escape }}"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          width="{{ logo_width }}"
          height="{{ logo_height }}"
        >
      </div>
    {%- endif -%}

    <div class="ai-age-verify-initial" data-age-initial>
      <div class="ai-age-verify-header">
        <div class="ai-age-verify-badge" aria-hidden="true">
          <svg width="30" height="30" viewBox="0 0 30 30" fill="none">
            <circle cx="15" cy="15" r="13" stroke="currentColor" stroke-width="2"></circle>
            <text x="15" y="19" text-anchor="middle" font-size="12" font-weight="900" fill="currentColor">18+</text>
          </svg>
        </div>
        <div>
          <p class="ai-age-verify-kicker">{{ block.settings.kicker_label }}</p>
          <h2 id="AgeVerifyTitle-{{ ai_gen_id }}" class="ai-age-verify-title">{{ block.settings.heading }}</h2>
          <div class="ai-age-verify-text">{{ block.settings.description }}</div>
        </div>
      </div>

      <div class="ai-age-verify-trust-row" aria-label="Garantías de verificación">
        <span class="ai-age-verify-trust-item">{{ block.settings.trust_item_1 }}</span>
        <span class="ai-age-verify-trust-item">{{ block.settings.trust_item_2 }}</span>
        <span class="ai-age-verify-trust-item">{{ block.settings.trust_item_3 }}</span>
      </div>

      <div class="ai-age-verify-actions">
        <button
          type="button"
          class="ai-age-verify-btn ai-age-verify-btn-yes"
          data-action="yes"
          data-autofocus
        >
          {{ block.settings.yes_label }}
        </button>
        <button type="button" class="ai-age-verify-btn ai-age-verify-btn-no" data-action="no">
          {{ block.settings.no_label }}
        </button>
      </div>

      <div class="ai-age-verify-note">
        {{ block.settings.note_text }}
      </div>
    </div>

    <div class="ai-age-verify-formwrap" data-age-formwrap hidden>
      <h3 class="ai-age-verify-title">{{ block.settings.form_heading }}</h3>
      <div class="ai-age-verify-text">{{ block.settings.form_description }}</div>

      <form data-age-form>
        <div class="ai-age-verify-field">
          <label class="ai-age-verify-label" for="AgeVerifyDob-{{ ai_gen_id }}">{{ block.settings.dob_label }}</label>
          <input
            id="AgeVerifyDob-{{ ai_gen_id }}"
            class="ai-age-verify-input"
            type="date"
            autocomplete="bday"
            required
            data-dob-input
            aria-describedby="AgeVerifyDobError-{{ ai_gen_id }}"
          >
          <div id="AgeVerifyDobError-{{ ai_gen_id }}" class="ai-age-verify-error" data-error="dob" aria-live="polite"></div>
        </div>

        <div class="ai-age-verify-field">
          <label class="ai-age-verify-label" for="AgeVerifyId-{{ ai_gen_id }}">{{ block.settings.id_label }}</label>
          <input
            id="AgeVerifyId-{{ ai_gen_id }}"
            class="ai-age-verify-input"
            type="text"
            placeholder="{{ block.settings.id_placeholder }}"
            inputmode="numeric"
            autocomplete="off"
            maxlength="10"
            required
            data-id-input
            aria-describedby="AgeVerifyIdError-{{ ai_gen_id }}"
          >
          <div id="AgeVerifyIdError-{{ ai_gen_id }}" class="ai-age-verify-error" data-error="id" aria-live="polite"></div>
        </div>

        <div class="ai-age-verify-actions">
          <button type="submit" class="ai-age-verify-submit">
            {{ block.settings.submit_label }}
          </button>
          <button type="button" class="ai-age-verify-submit-no" data-action="no">
            {{ block.settings.no_label }}
          </button>
        </div>

        <div class="ai-age-verify-note">
          {{ block.settings.privacy_note }}
        </div>

        <div class="ai-age-verify-error" data-error="cookie" aria-live="polite"></div>
      </form>
    </div>

    <div class="ai-age-verify-blocked" data-age-blocked hidden>
      <div class="ai-age-verify-blocked-icon" aria-hidden="true">
        <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="9"></circle>
          <path d="M8 8l8 8"></path>
        </svg>
      </div>
      <h3>{{ block.settings.blocked_heading }}</h3>
      <div class="ai-age-verify-text">{{ block.settings.blocked_message }}</div>
    </div>
  </div>
</age-verification-gate>

<script>
  (function () {
    var gate = document.getElementById('AgeVerification-{{ ai_gen_id }}');
    if (!gate || (window.Shopify && window.Shopify.designMode)) return;

    var cookieName = gate.getAttribute('data-cookie-name') || 'age_verified_diyvape';
    var safeName = cookieName.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    var cookieMatch = document.cookie.match(new RegExp('(?:^|; )' + safeName + '=([^;]*)'));
    var raw = cookieMatch ? cookieMatch[1] : null;

    if (!raw) {
      try {
        raw = localStorage.getItem(cookieName);
      } catch (error) {}
    }

    try {
      var data = JSON.parse(decodeURIComponent(raw || 'null'));
      if (data && data.verified && data.dob && data.id) return;
    } catch (error) {}

    document.documentElement.style.setProperty('--scroll-y', '-' + (window.scrollY || 0) + 'px');
    document.body.classList.add('ai-age-gate-open');
    gate.removeAttribute('aria-hidden');
    gate.classList.add('active');
  })();
</script>

<div class="ai-age-verify-editor-trigger" data-age-editor-trigger-for="AgeVerification-{{ ai_gen_id }}">
  <button type="button" aria-label="Preview age verification">Preview Age Verification</button>
</div>

{% schema %}
{
  "name": "Verificación edad Pop Up",
  "tag": null,
  "settings": [
    { "type": "header", "content": "Fondo de pantalla (overlay)" },
    { "type": "color", "id": "overlay_bg_color", "label": "Color overlay", "default": "#000000" },
    { "type": "range", "id": "overlay_opacity", "min": 0.0, "max": 1, "step": 0.1, "label": "Opacidad overlay", "default": 1 },

    { "type": "header", "content": "General" },
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    { "type": "range", "id": "logo_width", "min": 50, "max": 300, "step": 10, "unit": "px", "label": "Ancho del logo", "default": 150 },

    { "type": "header", "content": "Contenido" },
    { "type": "inline_richtext", "id": "kicker_label", "label": "Etiqueta superior", "default": "Acceso regulado" },
    { "type": "inline_richtext", "id": "heading", "label": "Título", "default": "Verificación de edad requerida" },
    { "type": "richtext", "id": "description", "label": "Descripción", "default": "<p>Debes tener 18 años o más para ingresar y comprar en este sitio.</p>" },
    { "type": "inline_richtext", "id": "trust_item_1", "label": "Etiqueta confianza 1", "default": "Mayoría de edad" },
    { "type": "inline_richtext", "id": "trust_item_2", "label": "Etiqueta confianza 2", "default": "Validación segura" },
    { "type": "inline_richtext", "id": "trust_item_3", "label": "Etiqueta confianza 3", "default": "Revisión checkout" },
    { "type": "inline_richtext", "id": "yes_label", "label": "Botón Sí", "default": "Soy mayor de 18" },
    { "type": "inline_richtext", "id": "no_label", "label": "Botón No", "default": "Soy menor de 18" },
    { "type": "richtext", "id": "note_text", "label": "Nota", "default": "<p>La información se usará para validar tu mayoría de edad y podrá verificarse en el checkout.</p>" },

    { "type": "inline_richtext", "id": "form_heading", "label": "Título formulario", "default": "Confirma tu información" },
    { "type": "richtext", "id": "form_description", "label": "Descripción formulario", "default": "<p>Ingresa tu fecha de nacimiento y tu número de identificación.</p>" },
    { "type": "inline_richtext", "id": "dob_label", "label": "Etiqueta DOB", "default": "Fecha de nacimiento" },
    { "type": "inline_richtext", "id": "id_label", "label": "Etiqueta ID", "default": "Número de identificación" },
    { "type": "inline_richtext", "id": "id_placeholder", "label": "Placeholder ID", "default": "Solo números (8 a 10 dígitos)" },
    { "type": "inline_richtext", "id": "submit_label", "label": "Botón enviar", "default": "Verificar e ingresar" },
    { "type": "inline_richtext", "id": "age_error_message", "label": "Error DOB", "default": "Verifica tu fecha de nacimiento. Debes ser mayor de 18 años." },
    { "type": "inline_richtext", "id": "id_error_message", "label": "Error ID", "default": "El número de identificación debe ser numérico y tener entre 8 y 10 dígitos." },
    { "type": "richtext", "id": "privacy_note", "label": "Nota privacidad", "default": "<p>Al continuar, declaras ser mayor de edad y autorizas el tratamiento de datos según nuestra Política de Privacidad.</p>" },

    { "type": "header", "content": "Bloqueo" },
    { "type": "inline_richtext", "id": "blocked_heading", "label": "Título bloqueo", "default": "Acceso denegado" },
    { "type": "richtext", "id": "blocked_message", "label": "Mensaje bloqueo", "default": "<p>Este sitio es exclusivo para mayores de edad.</p>" },

    { "type": "header", "content": "Editor (Theme Editor / design mode)" },
    {
      "type": "select",
      "id": "editor_mode_behavior",
      "label": "Comportamiento en editor",
      "default": "only_preview_button",
      "options": [
        { "value": "hide_in_editor", "label": "No mostrar en editor" },
        { "value": "show_in_editor", "label": "Mostrar en editor (normal)" },
        { "value": "only_preview_button", "label": "Solo mostrar botón de preview" }
      ]
    },

    { "type": "header", "content": "Cookie (compatibilidad + persistencia avanzada)" },
    { "type": "text", "id": "cookie_name", "label": "Nombre cookie", "default": "age_verified_diyvape" },
    { "type": "text", "id": "cookie_domain", "label": "Dominio cookie", "default": ".diyvape.co" },

    {
      "type": "select",
      "id": "cookie_duration",
      "label": "Duración cookie (legacy - días)",
      "default": "365",
      "options": [
        { "value": "7", "label": "7 días" },
        { "value": "30", "label": "30 días" },
        { "value": "90", "label": "90 días" },
        { "value": "180", "label": "180 días" },
        { "value": "365", "label": "365 días" }
      ]
    },

    {
      "type": "select",
      "id": "cookie_persistence",
      "label": "Modo de persistencia",
      "default": "legacy_days",
      "options": [
        { "value": "legacy_days", "label": "Usar duración legacy (días)" },
        { "value": "session", "label": "Sesión (se borra al cerrar navegador)" },
        { "value": "hours", "label": "Horas" },
        { "value": "days", "label": "Días (selector v2)" },
        { "value": "custom", "label": "Personalizado (valor + unidad)" }
      ]
    },
    {
      "type": "select",
      "id": "cookie_hours",
      "label": "Horas (si modo = Horas)",
      "default": "24",
      "options": [
        { "value": "6", "label": "6 horas" },
        { "value": "12", "label": "12 horas" },
        { "value": "24", "label": "24 horas" }
      ]
    },
    {
