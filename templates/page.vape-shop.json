    "custom_liquid_L6AjW3": {
      "type": "custom-liquid",
      "name": "t:sections.custom_liquid.name",
      "settings": {
        "section_width": "container",
        "color_scheme": "scheme-cad2a0ec-e8e4-4844-b669-ed3f593863ca",
        "custom_liquid": "{%- if page.title != blank -%}\n<style>\n  .diy-collapsible-wrap {\n    --lab-red:  #C8102E;\n    --carbon:   #0A0A0A;\n    --bone:     #F5F2EC;\n    --steel:    #AAAAAA;\n    background: var(--carbon);\n    border-radius: 2px;\n    padding: 0;\n    position: relative;\n    margin: 2rem 0;\n    border-left: 3px solid var(--lab-red);\n  }\n  .diy-toggle-btn {\n    display: flex; align-items: center; justify-content: space-between;\n    gap: 16px; width: 100%; background: none; border: none;\n    border-bottom: 1px solid #1f1f1f;\n    padding: 18px 24px 18px 28px; cursor: pointer; text-align: left;\n    transition: background 0.2s;\n  }\n  .diy-toggle-btn:hover { background: rgba(200,16,46,0.04); }\n  .diy-eyebrow {\n    font-size: 10px; font-weight: 700; letter-spacing: 0.2em;\n    text-transform: uppercase; color: var(--lab-red);\n    display: block; margin-bottom: 6px;\n  }\n  .diy-title-text {\n    font-size: 14px; font-weight: 600; color: var(--bone);\n    line-height: 1.4; transition: color 0.2s; display: block;\n  }\n  .diy-toggle-btn:hover .diy-title-text { color: #FFFFFF; }\n  .diy-icon {\n    flex-shrink: 0; width: 26px; height: 26px;\n    border: 1px solid #2e2e2e; border-radius: 50%;\n    display: flex; align-items: center; justify-content: center;\n    position: relative; transition: border-color 0.2s;\n  }\n  .diy-toggle-btn:hover .diy-icon,\n  .diy-toggle-btn.open .diy-icon { border-color: var(--lab-red); }\n  .diy-icon-bar {\n    position: absolute; background: #555; border-radius: 1px;\n    transition: transform 0.28s ease, opacity 0.28s ease, background 0.2s;\n  }\n  .diy-icon-bar.h { width: 10px; height: 1.5px; }\n  .diy-icon-bar.v { width: 1.5px; height: 10px; }\n  .diy-toggle-btn:hover .diy-icon-bar,\n  .diy-toggle-btn.open .diy-icon-bar { background: var(--lab-red); }\n  .diy-toggle-btn.open .diy-icon-bar.v { transform: rotate(90deg); opacity: 0; }\n  .diy-content-outer {\n    overflow: hidden; max-height: 0; opacity: 0;\n    transition: max-height 0.42s cubic-bezier(0.4,0,0.2,1), opacity 0.32s ease;\n  }\n  .diy-content-outer.open { opacity: 1; }\n  .diy-content-inner { padding: 20px 28px 28px; line-height: 1.8; }\n  .diy-divider {\n    display: block; height: 1px; margin-bottom: 20px; opacity: 0.5;\n    background: linear-gradient(to right, var(--lab-red) 0%, #2a0008 60%, transparent 100%);\n  }\n  .diy-rich-text * { color: var(--steel) !important; }\n  .diy-rich-text h1, .diy-rich-text h2,\n  .diy-rich-text h3, .diy-rich-text h4 {\n    font-size: 15px !important; font-weight: 700 !important;\n    color: var(--bone) !important; margin: 0 0 14px !important;\n    line-height: 1.35 !important;\n  }\n  .diy-rich-text p {\n    color: var(--steel) !important;\n    margin: 0 0 12px !important; font-size: 14px !important;\n  }\n  .diy-rich-text p:last-child { margin-bottom: 0 !important; }\n  .diy-rich-text a {\n    color: var(--lab-red) !important;\n    text-decoration: underline !important;\n    text-underline-offset: 3px !important;\n  }\n  .diy-rich-text a:hover { color: #ff2040 !important; }\n  .diy-rich-text strong, .diy-rich-text b {\n    color: var(--bone) !important; font-weight: 600 !important;\n  }\n  .diy-rich-text ul, .diy-rich-text ol {\n    color: var(--steel) !important;\n    padding-left: 18px !important; margin: 0 0 12px !important;\n  }\n  .diy-rich-text li { color: var(--steel) !important; margin-bottom: 4px !important; }\n<\/style>\n\n<div class=\"diy-collapsible-wrap\">\n  <button\n    class=\"diy-toggle-btn\"\n    id=\"diyToggle-{{ page.id }}\"\n    onclick=\"toggleDiyBlock('{{ page.id }}')\"\n    aria-expanded=\"false\"\n    aria-controls=\"diyContent-{{ page.id }}\"\n  >\n    <span>\n      <span class=\"diy-eyebrow\">DIY Vape Shop · Guía de colección<\/span>\n      <span class=\"diy-title-text\">\n        #1 en Colombia |\n        <em style=\"font-style:normal;color:var(--lab-red);\">{{ page.title }}<\/em>\n        | Tienda de Vapeo\n      <\/span>\n    <\/span>\n    <span class=\"diy-icon\" id=\"diyIcon-{{ page.id }}\">\n      <span class=\"diy-icon-bar h\"><\/span>\n      <span class=\"diy-icon-bar v\"><\/span>\n    <\/span>\n  <\/button>\n\n  <div class=\"diy-content-outer\" id=\"diyContent-{{ page.id }}\">\n    <div class=\"diy-content-inner\">\n      <span class=\"diy-divider\"><\/span>\n      <div class=\"diy-rich-text\">\n        {{ page.content }}\n      <\/div>\n    <\/div>\n  <\/div>\n<\/div>\n\n<script>\nfunction toggleDiyBlock(id) {\n  var btn = document.getElementById('diyToggle-' + id);\n  var content = document.getElementById('diyContent-' + id);\n  if (!btn || !content) return;\n  var isOpen = btn.classList.contains('open');\n  if (isOpen) {\n    content.style.maxHeight = content.scrollHeight + 'px';\n    requestAnimationFrame(function() {\n      content.style.maxHeight = '0px';\n      content.classList.remove('open');\n      btn.classList.remove('open');\n      btn.setAttribute('aria-expanded','false');\n    });\n  } else {\n    btn.classList.add('open');\n    content.classList.add('open');\n    content.style.maxHeight = content.scrollHeight + 'px';\n    btn.setAttribute('aria-expanded','true');\n    content.addEventListener('transitionend', function() {\n      if (btn.classList.contains('open')) content.style.maxHeight = 'none';\n    }, { once: true });\n  }\n}\n<\/script>\n{%- endif -%}",
        "padding_top": 0,
        "padding_bottom": 0,
        "reset_spacing": false
      }
    }
  },
