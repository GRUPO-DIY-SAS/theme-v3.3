{%- comment -%} ===== CSS v3.1 ===== {%- endcomment -%}
<style>
  @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&family=Open+Sans:wght@400;500;600&family=Oswald:wght@600;700&display=swap');

  /* ── Design Tokens ── */
  :root{
    --diy-rojo:#C8102E;--diy-negro:#000;--diy-blanco:#FFF;--diy-rojo-oscuro:#8B0000;--diy-rojo-glow:rgba(200,16,46,.35);
    --diy-g900:#111;--diy-g800:#1a1a1a;--diy-g700:#333;--diy-g600:#555;--diy-g500:#666;--diy-g300:#999;
    --diy-g200:#E8E8E8;--diy-g100:#F5F5F5;--diy-g50:#FAFAFA;
    --diy-wa:#25D366;--diy-wa-h:#1fb855;
    --diy-fh:'Montserrat',system-ui,sans-serif;--diy-fb:'Open Sans',system-ui,sans-serif;--diy-fp:'Oswald',system-ui,sans-serif;
    --diy-ease:cubic-bezier(.4,0,.2,1);
    --diy-sh-sm:0 1px 3px rgba(0,0,0,.06);--diy-sh-md:0 4px 20px rgba(0,0,0,.08);--diy-sh-lg:0 12px 40px rgba(0,0,0,.12);
    --diy-sh-red:0 8px 32px rgba(200,16,46,.2);--diy-sh-wa:0 8px 28px rgba(37,211,102,.25);
    --diy-r-sm:8px;--diy-r-md:16px;--diy-r-lg:24px;--diy-r-xl:32px;--diy-r-full:9999px
  }
  .ws{font-family:var(--diy-fb);color:var(--diy-g700);line-height:1.6;-webkit-font-smoothing:antialiased;overflow-x:hidden}
  .ws *,.ws *::before,.ws *::after{box-sizing:border-box;margin:0;padding:0}
  .ws img{max-width:100%;height:auto;display:block}
  .ws a{text-decoration:none;color:inherit}
  .ws-wrap{max-width:1200px;margin:0 auto;padding:0 24px}
  .ws-wrap--lg{max-width:1320px;margin:0 auto;padding:0 24px}

  /* ── Keyframes ── */
  @keyframes ws-float{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}
  @keyframes ws-pulse{0%,100%{opacity:1}50%{opacity:.5}}
  @keyframes ws-gradient{0%{background-position:0% 50%}50%{background-position:100% 50%}100%{background-position:0% 50%}}
  @keyframes ws-glow{0%,100%{box-shadow:0 0 24px rgba(200,16,46,.12)}50%{box-shadow:0 0 48px rgba(200,16,46,.28)}}
  @keyframes ws-shine{0%{transform:translateX(-100%)}100%{transform:translateX(100%)}}
  @keyframes ws-slide-up{from{opacity:0;transform:translateY(32px)}to{opacity:1;transform:translateY(0)}}

  /* ── Buttons v3 ── */
  .ws-btn{display:inline-flex;align-items:center;justify-content:center;gap:10px;font-family:var(--diy-fh);font-weight:700;font-size:15px;padding:16px 36px;border-radius:var(--diy-r-sm);text-decoration:none;transition:all .25s var(--diy-ease);cursor:pointer;border:none;line-height:1;position:relative;overflow:hidden;letter-spacing:.3px}
  .ws-btn::after{content:'';position:absolute;inset:0;background:linear-gradient(120deg,transparent 30%,rgba(255,255,255,.12) 50%,transparent 70%);transform:translateX(-100%);transition:transform .5s var(--diy-ease)}
  .ws-btn:hover::after{transform:translateX(100%)}
  .ws-btn:active{transform:scale(.98)!important}
  .ws-btn--primary{background:var(--diy-rojo);color:var(--diy-blanco)!important;font-size:16px;padding:18px 40px;border-radius:var(--diy-r-full)}
  .ws-btn--primary svg{fill:var(--diy-blanco);color:var(--diy-blanco)}
  .ws-btn--primary:hover{background:var(--diy-rojo-oscuro);transform:translateY(-3px);box-shadow:var(--diy-sh-red)}
  .ws-btn--ghost{background:rgba(255,255,255,.06);color:var(--diy-blanco)!important;border:1.5px solid rgba(255,255,255,.18);backdrop-filter:blur(8px);border-radius:var(--diy-r-full);padding:18px 40px;font-size:16px}
  .ws-btn--ghost svg{stroke:var(--diy-blanco);color:var(--diy-blanco)}
  .ws-btn--ghost:hover{background:rgba(255,255,255,.12);border-color:rgba(255,255,255,.5);transform:translateY(-3px)}
  .ws-btn--wa{background:var(--diy-wa);color:var(--diy-blanco)!important;font-size:17px;padding:20px 44px;border-radius:var(--diy-r-full)}
  .ws-btn--wa svg{fill:var(--diy-blanco);color:var(--diy-blanco)}
  .ws-btn--wa:hover{background:var(--diy-wa-h);transform:translateY(-3px);box-shadow:var(--diy-sh-wa)}
  .ws-btn--outline-dark{background:transparent;color:var(--diy-blanco)!important;border:2px solid rgba(255,255,255,.25);font-size:17px;padding:20px 44px;border-radius:var(--diy-r-full)}
  .ws-btn--outline-dark svg{stroke:var(--diy-blanco);color:var(--diy-blanco)}
  .ws-btn--outline-dark:hover{border-color:var(--diy-blanco);background:rgba(255,255,255,.06);transform:translateY(-3px)}
  .ws-btn--outline{background:transparent;color:var(--diy-rojo);border:2px solid var(--diy-rojo);font-size:14px;padding:14px 28px;border-radius:var(--diy-r-sm)}
  .ws-btn--outline:hover{background:var(--diy-rojo);color:var(--diy-blanco);transform:translateY(-2px)}
  .ws-btn--sm{font-size:13px;padding:12px 24px}

  /* ══════════════════════════ HERO v3 ══════════════════════════ */
  .ws-hero{background:var(--diy-negro);position:relative;overflow:hidden;min-height:680px;display:flex;align-items:center;padding:80px 0 60px}
  .ws-hero__bg{position:absolute;inset:0;z-index:0}
  .ws-hero__bg::before{content:'';position:absolute;inset:0;background:
    radial-gradient(ellipse 60% 50% at 20% 80%,rgba(200,16,46,.10) 0%,transparent 60%),
    radial-gradient(ellipse 50% 60% at 80% 30%,rgba(200,16,46,.07) 0%,transparent 55%)}
  .ws-hero__bg::after{content:'';position:absolute;inset:0;background:
    linear-gradient(135deg,rgba(0,0,0,.85) 0%,rgba(0,0,0,.55) 40%,rgba(0,0,0,.3) 70%,rgba(0,0,0,.6) 100%)}
  .ws-hero__pattern{position:absolute;inset:0;background-image:
    radial-gradient(circle at 1px 1px,rgba(255,255,255,.03) 1px,transparent 0);
    background-size:40px 40px;z-index:0}
  .ws-hero__grid{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center;position:relative;z-index:1}

  /* Hero Left */
  .ws-hero__badge{display:inline-flex;align-items:center;gap:8px;background:rgba(200,16,46,.08);border:1px solid rgba(200,16,46,.2);border-radius:var(--diy-r-full);padding:8px 20px;margin-bottom:28px}
  .ws-hero__badge svg{color:var(--diy-rojo);flex-shrink:0}
  .ws-hero__badge span{font-family:var(--diy-fh);font-weight:600;font-size:11px;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,.8)}
  .ws-hero__title{font-family:var(--diy-fh);font-weight:900;font-size:clamp(34px,4.5vw,56px);line-height:1.08;color:var(--diy-blanco)!important;margin-bottom:24px;letter-spacing:-.5px}
  .ws-hero__title em{font-style:normal;background:linear-gradient(135deg,var(--diy-rojo),#ff3d5a);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;display:block}
  .ws-hero__title-white{background:none!important;-webkit-background-clip:unset!important;-webkit-text-fill-color:var(--diy-blanco)!important;background-clip:unset!important;color:var(--diy-blanco)!important}
  .ws-hero__sub{font-size:17px;color:rgba(255,255,255,.65);max-width:500px;margin-bottom:36px;line-height:1.75}
  .ws-hero__ctas{display:flex;gap:16px;flex-wrap:wrap;margin-bottom:48px}

  /* Hero Proof Pills */
  .ws-hero__proof{display:flex;gap:12px;flex-wrap:wrap}
  .ws-hero__pill{display:flex;align-items:center;gap:8px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:var(--diy-r-full);padding:10px 18px;transition:all .25s var(--diy-ease)}
  .ws-hero__pill:hover{border-color:rgba(200,16,46,.25);background:rgba(255,255,255,.07)}
  .ws-hero__pill svg{width:16px;height:16px;color:var(--diy-rojo);flex-shrink:0}
  .ws-hero__pill-num{font-family:var(--diy-fp);font-weight:700;font-size:18px;color:var(--diy-blanco);line-height:1}
  .ws-hero__pill-label{font-size:11px;font-weight:600;color:rgba(255,255,255,.5);text-transform:uppercase;letter-spacing:.5px}

  /* Hero Right — Product Showcase */
  .ws-hero__visual{position:relative}
  .ws-hero__showcase{display:grid;grid-template-columns:1fr 1fr;gap:16px;max-width:480px;margin:0 auto}
  .ws-hero__card{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:var(--diy-r-md);padding:20px 16px 16px;text-align:center;transition:all .35s var(--diy-ease);position:relative;animation:ws-float 5s var(--diy-ease) infinite;cursor:pointer}
  .ws-hero__card:nth-child(2){animation-delay:.6s}
  .ws-hero__card:nth-child(3){animation-delay:1.2s}
  .ws-hero__card:nth-child(4){animation-delay:1.8s}
  .ws-hero__card:hover{border-color:rgba(200,16,46,.4);background:rgba(255,255,255,.08);transform:translateY(-6px) scale(1.02)}
  .ws-hero__card-badge{position:absolute;top:10px;right:10px;background:var(--diy-rojo);color:var(--diy-blanco);font-family:var(--diy-fh);font-weight:700;font-size:10px;padding:4px 10px;border-radius:var(--diy-r-full);letter-spacing:.3px;z-index:1}
  .ws-hero__card img{width:80%;max-height:140px;aspect-ratio:1;object-fit:contain;margin:0 auto 12px;filter:drop-shadow(0 8px 20px rgba(0,0,0,.4));transition:transform .4s var(--diy-ease)}
  .ws-hero__card:hover img{transform:scale(1.08)}
  .ws-hero__card-name{font-family:var(--diy-fh);font-weight:600;font-size:12px;color:rgba(255,255,255,.85);margin-bottom:6px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .ws-hero__card-meta{display:flex;align-items:center;justify-content:center;gap:8px}
  .ws-hero__card-price{font-family:var(--diy-fp);font-weight:700;font-size:18px;color:var(--diy-rojo)}
  .ws-hero__card-stock{display:flex;align-items:center;gap:3px;font-size:10px;color:var(--diy-wa);font-weight:600}
  .ws-hero__card-stock svg{width:8px;height:8px}
  .ws-hero__disclaimer{text-align:center;font-size:11px;color:rgba(255,255,255,.4);margin-top:16px;max-width:480px;margin-left:auto;margin-right:auto;line-height:1.5}

  /* ── Stats Bar v3 — Glass style ── */
  .ws-stats{background:linear-gradient(135deg,var(--diy-rojo),#e8173a,var(--diy-rojo));background-size:200% 200%;animation:ws-gradient 6s ease infinite;position:relative;z-index:2}
  .ws-stats__inner{display:grid;grid-template-columns:repeat(4,1fr)}
  .ws-stat{padding:32px 16px;text-align:center;position:relative;transition:background .25s var(--diy-ease)}
  .ws-stat:hover{background:rgba(0,0,0,.08)}
  .ws-stat + .ws-stat::before{content:'';position:absolute;left:0;top:20%;height:60%;width:1px;background:rgba(255,255,255,.2)}
  .ws-stat__num{font-family:var(--diy-fp);font-weight:700;font-size:clamp(30px,3.5vw,42px);color:var(--diy-blanco);line-height:1;margin-bottom:6px}
  .ws-stat__label{font-family:var(--diy-fh);font-weight:500;font-size:12px;color:rgba(255,255,255,.85);text-transform:uppercase;letter-spacing:1.5px}

  /* ── Section Commons ── */
  .ws-sec{padding:96px 0}
  .ws-sec--alt{background:var(--diy-g100)}
  .ws-sec--dark{background:var(--diy-negro);color:var(--diy-blanco)}
  .ws-sec__head{text-align:center;margin-bottom:64px}
  .ws-tag{display:inline-flex;align-items:center;gap:8px;font-family:var(--diy-fh);font-weight:700;font-size:11px;color:var(--diy-rojo);text-transform:uppercase;letter-spacing:2.5px;margin-bottom:16px}
  .ws-tag::before,.ws-tag::after{content:'';width:24px;height:2px;background:var(--diy-rojo);border-radius:1px}
  .ws-sec__title{font-family:var(--diy-fh);font-weight:800;font-size:clamp(28px,3.2vw,42px);color:var(--diy-negro);line-height:1.12;margin-bottom:18px;letter-spacing:-.3px}
  .ws-sec--dark .ws-sec__title{color:var(--diy-blanco)}
  .ws-sec__desc{font-size:16px;color:var(--diy-g500);max-width:580px;margin:0 auto;line-height:1.75}
  .ws-sec--dark .ws-sec__desc{color:rgba(255,255,255,.55)}

  /* ══════════════════════════ BENEFITS v3 ══════════════════════════ */
  .ws-bens{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
  .ws-ben{background:var(--diy-blanco);border:1px solid var(--diy-g200);border-radius:var(--diy-r-lg);padding:36px 28px;transition:all .35s var(--diy-ease);position:relative;overflow:hidden}
  .ws-ben::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--diy-rojo),#ff5e6e);transform:scaleX(0);transition:transform .35s var(--diy-ease);transform-origin:left}
  .ws-ben:hover{box-shadow:var(--diy-sh-lg);border-color:transparent;transform:translateY(-6px)}
  .ws-ben:hover::before{transform:scaleX(1)}
  .ws-ben__icon{width:56px;height:56px;border-radius:16px;background:linear-gradient(135deg,rgba(200,16,46,.06),rgba(200,16,46,.12));display:flex;align-items:center;justify-content:center;margin-bottom:20px;color:var(--diy-rojo);transition:all .35s var(--diy-ease)}
  .ws-ben:hover .ws-ben__icon{background:linear-gradient(135deg,var(--diy-rojo),#e8173a);color:var(--diy-blanco);transform:scale(1.06);box-shadow:0 6px 20px rgba(200,16,46,.2)}
  .ws-ben__icon svg{width:24px;height:24px}
  .ws-ben__title{font-family:var(--diy-fh);font-weight:700;font-size:17px;color:var(--diy-negro);margin-bottom:10px}
  .ws-ben__text{font-size:14px;color:var(--diy-g500);line-height:1.7}

  /* ══════════════════════════ CATEGORY CARDS v3.1 — Icon Style ══════════════════════════ */
  .ws-cats{display:grid;grid-template-columns:repeat(3,1fr);gap:28px}
  .ws-cat{border-radius:var(--diy-r-xl);overflow:hidden;background:var(--diy-blanco);box-shadow:var(--diy-sh-sm);transition:all .4s var(--diy-ease);color:inherit;display:flex;flex-direction:column;border:1px solid var(--diy-g200)}
  .ws-cat:hover{box-shadow:var(--diy-sh-lg);transform:translateY(-8px);border-color:transparent}
  .ws-cat__visual{height:160px;background:linear-gradient(135deg,var(--diy-g100),var(--diy-g200));position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center}
  .ws-cat__visual img{width:50%;max-height:100px;object-fit:contain;transition:transform .5s var(--diy-ease);filter:drop-shadow(0 4px 12px rgba(0,0,0,.1))}
  .ws-cat:hover .ws-cat__visual img{transform:scale(1.1) translateY(-4px)}
  .ws-cat__body{padding:24px;flex:1;display:flex;flex-direction:column}
  .ws-cat__name{font-family:var(--diy-fh);font-weight:700;font-size:20px;color:var(--diy-negro);margin-bottom:8px}
  .ws-cat__desc{font-size:14px;color:var(--diy-g500);margin-bottom:auto;line-height:1.65;flex:1}
  .ws-cat__foot{display:flex;align-items:center;justify-content:space-between;margin-top:18px;padding-top:18px;border-top:1px solid var(--diy-g200)}
  .ws-cat__link{font-family:var(--diy-fh);font-weight:700;font-size:13px;color:var(--diy-rojo);display:inline-flex;align-items:center;gap:6px;transition:gap .25s var(--diy-ease)}
  .ws-cat:hover .ws-cat__link{gap:10px}
  .ws-cat__link svg{width:16px;height:16px;transition:transform .25s var(--diy-ease)}
  .ws-cat:hover .ws-cat__link svg{transform:translateX(3px)}
  .ws-cat__prices{font-size:12px;color:var(--diy-g500)}
  .ws-cat__prices strong{color:var(--diy-negro)}

  /* ══════════════════════════ PRODUCT PREVIEW CARDS v3 ══════════════════════════ */
  .ws-products{display:grid;grid-template-columns:repeat(4,1fr);gap:20px}
  .ws-prod{background:var(--diy-blanco);border:1px solid var(--diy-g200);border-radius:var(--diy-r-md);overflow:hidden;transition:all .35s var(--diy-ease);color:inherit;display:block;position:relative}
  .ws-prod:hover{box-shadow:var(--diy-sh-lg);border-color:transparent;transform:translateY(-6px)}
  .ws-prod__img{aspect-ratio:1;background:var(--diy-g100);display:flex;align-items:center;justify-content:center;padding:20px;overflow:hidden;position:relative}
  .ws-prod__img::after{content:'';position:absolute;bottom:0;left:0;right:0;height:40%;background:linear-gradient(to top,rgba(245,245,245,.9),transparent);pointer-events:none}
  .ws-prod__img img{width:80%;height:80%;object-fit:contain;transition:transform .4s var(--diy-ease);position:relative;z-index:1;filter:drop-shadow(0 4px 12px rgba(0,0,0,.08))}
  .ws-prod:hover .ws-prod__img img{transform:scale(1.1)}
  .ws-prod__tag{position:absolute;top:12px;left:12px;background:var(--diy-rojo);color:var(--diy-blanco);font-family:var(--diy-fh);font-weight:700;font-size:10px;padding:5px 12px;border-radius:var(--diy-r-full);z-index:2;letter-spacing:.3px}
  .ws-prod__body{padding:16px 18px}
  .ws-prod__brand{font-family:var(--diy-fh);font-weight:600;font-size:10px;text-transform:uppercase;letter-spacing:1.5px;color:var(--diy-g300);margin-bottom:6px}
  .ws-prod__name{font-family:var(--diy-fh);font-weight:700;font-size:14px;color:var(--diy-negro);margin-bottom:10px;line-height:1.35;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
  .ws-prod__meta{display:flex;align-items:center;justify-content:space-between}
  .ws-prod__price{font-family:var(--diy-fp);font-weight:700;font-size:20px;color:var(--diy-rojo)}
  .ws-prod__price-label{font-family:var(--diy-fh);font-size:10px;font-weight:600;color:var(--diy-g500);text-transform:uppercase;letter-spacing:.5px;display:block;margin-bottom:2px}
  .ws-prod__stock{display:flex;align-items:center;gap:4px;font-size:11px;font-weight:600}
  .ws-prod__stock--in{color:var(--diy-wa)}
  .ws-prod__stock svg{width:10px;height:10px}
  .ws-prod__cta{display:block;text-align:center;padding:12px;background:var(--diy-g50);font-family:var(--diy-fh);font-weight:700;font-size:12px;color:var(--diy-rojo);text-transform:uppercase;letter-spacing:.8px;transition:all .25s var(--diy-ease);border-top:1px solid var(--diy-g200)}
  .ws-prod:hover .ws-prod__cta{background:var(--diy-rojo);color:var(--diy-blanco);border-color:var(--diy-rojo)}

  /* ── Brands v3.1 — with links ── */
  .ws-brands{display:grid;grid-template-columns:repeat(6,1fr);gap:16px}
  .ws-brand{background:var(--diy-blanco);border:1px solid var(--diy-g200);border-radius:var(--diy-r-md);height:80px;display:flex;align-items:center;justify-content:center;transition:all .25s var(--diy-ease);cursor:default}
  .ws-brand:hover{border-color:var(--diy-rojo);box-shadow:0 4px 16px rgba(200,16,46,.08);transform:translateY(-3px)}
  .ws-brand span{font-family:var(--diy-fh);font-weight:700;font-size:13px;color:var(--diy-g500);text-transform:uppercase;letter-spacing:1px;transition:color .25s var(--diy-ease)}
  .ws-brand:hover span{color:var(--diy-rojo)}
  a.ws-brand{cursor:pointer}
  a.ws-brand:hover{background:rgba(200,16,46,.03)}

  /* ── Process v3 ── */
  .ws-steps{display:grid;grid-template-columns:repeat(3,1fr);gap:48px;position:relative}
  .ws-steps::before{content:'';position:absolute;top:52px;left:calc(16.66% + 28px);right:calc(16.66% + 28px);height:2px;background:linear-gradient(90deg,var(--diy-rojo),var(--diy-g200),var(--diy-rojo));z-index:0}
  .ws-step{text-align:center;position:relative;z-index:1}
  .ws-step__circle{width:104px;height:104px;border-radius:50%;background:var(--diy-blanco);border:3px solid var(--diy-rojo);display:flex;align-items:center;justify-content:center;margin:0 auto 28px;transition:all .4s var(--diy-ease);position:relative;box-shadow:var(--diy-sh-sm)}
  .ws-step:hover .ws-step__circle{background:linear-gradient(135deg,var(--diy-rojo),#e8173a);animation:ws-glow 2.5s var(--diy-ease) infinite;box-shadow:var(--diy-sh-red)}
  .ws-step__circle svg{width:36px;height:36px;color:var(--diy-rojo);transition:color .4s var(--diy-ease)}
  .ws-step:hover .ws-step__circle svg{color:var(--diy-blanco)}
  .ws-step__num{position:absolute;top:-6px;right:-6px;width:30px;height:30px;border-radius:50%;background:var(--diy-rojo);color:var(--diy-blanco);font-family:var(--diy-fp);font-weight:700;font-size:15px;display:flex;align-items:center;justify-content:center;box-shadow:0 2px 8px rgba(200,16,46,.3)}
  .ws-step__title{font-family:var(--diy-fh);font-weight:700;font-size:19px;color:var(--diy-negro);margin-bottom:10px}
  .ws-step__desc{font-size:14px;color:var(--diy-g500);max-width:280px;margin:0 auto;line-height:1.65}

  /* ── FAQ v3 ── */
  .ws-faq{max-width:800px;margin:0 auto}
  .ws-faq__item{border:1px solid var(--diy-g200);border-radius:var(--diy-r-md);margin-bottom:12px;overflow:hidden;background:var(--diy-blanco);transition:all .25s var(--diy-ease)}
  .ws-faq__item:hover{border-color:rgba(200,16,46,.25)}
  .ws-faq__item[open]{border-color:var(--diy-rojo);box-shadow:0 4px 16px rgba(200,16,46,.06)}
  .ws-faq__q{font-family:var(--diy-fh);font-weight:600;font-size:15px;color:var(--diy-negro);padding:20px 24px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;gap:16px;list-style:none;user-select:none;transition:color .25s var(--diy-ease)}
  .ws-faq__q::-webkit-details-marker{display:none}
  .ws-faq__item[open] .ws-faq__q{color:var(--diy-rojo)}
  .ws-faq__chevron{flex-shrink:0;width:24px;height:24px;color:var(--diy-g500);transition:all .3s var(--diy-ease)}
  .ws-faq__item[open] .ws-faq__chevron{transform:rotate(180deg);color:var(--diy-rojo)}
  .ws-faq__a{padding:0 24px 20px;font-size:14px;color:var(--diy-g500);line-height:1.75}

  /* ══════════════════════════ CTA FINAL v3 ══════════════════════════ */
  .ws-final{background:var(--diy-negro);padding:120px 0;text-align:center;position:relative;overflow:hidden}
  .ws-final__bg{position:absolute;inset:0}
  .ws-final__bg::before{content:'';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:800px;height:800px;border-radius:50%;background:radial-gradient(circle,rgba(200,16,46,.08) 0%,transparent 65%);animation:ws-pulse 5s var(--diy-ease) infinite}
  .ws-final__bg::after{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 30% 70%,rgba(200,16,46,.05) 0%,transparent 50%)}
  .ws-final .ws-wrap{position:relative;z-index:1}
  .ws-final__tag{font-family:var(--diy-fh);font-weight:700;font-size:11px;color:var(--diy-rojo);text-transform:uppercase;letter-spacing:3px;margin-bottom:20px;display:block}
  .ws-final__title{font-family:var(--diy-fh);font-weight:900;font-size:clamp(30px,4vw,48px);color:var(--diy-blanco);margin-bottom:18px;line-height:1.1;letter-spacing:-.5px}
  .ws-final__desc{font-size:18px;color:rgba(255,255,255,.55);margin-bottom:48px;max-width:520px;margin-left:auto;margin-right:auto;line-height:1.7}
  .ws-final__btns{display:flex;gap:16px;justify-content:center;flex-wrap:wrap}

  /* ── Trust E-E-A-T ── */
  .ws-trust{padding:64px 0;border-top:1px solid var(--diy-g200)}
  .ws-trust__grid{display:grid;grid-template-columns:repeat(4,1fr);gap:24px;text-align:center}
  .ws-trust__item{display:flex;flex-direction:column;align-items:center;gap:8px}
  .ws-trust__item svg{width:28px;height:28px;color:var(--diy-rojo);margin-bottom:4px}
  .ws-trust__item strong{font-family:var(--diy-fh);font-weight:700;font-size:14px;color:var(--diy-negro)}
  .ws-trust__item span{font-size:12px;color:var(--diy-g500)}
  .ws-warning{background:var(--diy-g100);border:1px solid var(--diy-g200);border-radius:var(--diy-r-sm);padding:16px 24px;margin-top:36px;text-align:center;display:flex;align-items:center;justify-content:center;gap:10px}
  .ws-warning svg{width:20px;height:20px;color:#F59E0B;flex-shrink:0}
  .ws-warning p{font-size:12px;color:var(--diy-g500);font-weight:500;margin:0}

  /* ══════════════════════════ RESPONSIVE v3 ══════════════════════════ */
  @media(max-width:1024px){
    .ws-hero{min-height:auto;padding:56px 0 48px}
    .ws-hero__grid{grid-template-columns:1fr;text-align:center}
    .ws-hero__sub{margin-left:auto;margin-right:auto}
    .ws-hero__ctas{justify-content:center}
    .ws-hero__proof{justify-content:center}
    .ws-hero__visual{margin-top:40px}
    .ws-hero__showcase{max-width:400px}
    .ws-bens,.ws-cats,.ws-steps{grid-template-columns:1fr 1fr}
    .ws-products{grid-template-columns:repeat(2,1fr)}
    .ws-brands{grid-template-columns:repeat(3,1fr)}
    .ws-trust__grid{grid-template-columns:repeat(2,1fr)}
    .ws-steps::before{display:none}
  }
  @media(max-width:600px){
    .ws-hero{padding:40px 0}
    .ws-hero__showcase{grid-template-columns:1fr 1fr;max-width:320px}
    .ws-hero__proof{flex-direction:column;align-items:center}
    .ws-sec{padding:64px 0}
    .ws-bens,.ws-cats,.ws-steps{grid-template-columns:1fr}
    .ws-products{grid-template-columns:1fr 1fr}
    .ws-brands{grid-template-columns:repeat(2,1fr)}
    .ws-trust__grid{grid-template-columns:1fr 1fr}
    .ws-stats__inner{grid-template-columns:repeat(2,1fr)}
    .ws-stat + .ws-stat:nth-child(3)::before{display:none}
    .ws-btn--primary,.ws-btn--wa,.ws-btn--ghost,.ws-btn--outline-dark{padding:16px 28px;font-size:14px}
    .ws-final{padding:80px 0}
  }

  /* ── Reduced motion ── */
  @media(prefers-reduced-motion:reduce){
    .ws-hero__card{animation:none}
    .ws-final__bg::before{animation:none}
    .ws-stats{animation:none}
    .ws-step:hover .ws-step__circle{animation:none}
    .ws-btn::after{display:none}
    *{transition-duration:0.01ms!important;animation-duration:0.01ms!important}
  }
</style>

